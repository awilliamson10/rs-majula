[oploc1,shadelair_bronzedoor]
switch_coord(loc_coord) {
    case 0_54_151_37_62 : @catacombs_exit;
    case default : @catacombs_open_door(~check_axis(coord, loc_coord, loc_angle));
}

[oploc1,shadelair_steeldoor]
def_boolean $entering = ~check_axis(coord, loc_coord, loc_angle);
if($entering = true) {
    if(inv_totalcat(inv, category_113) = 0 & inv_totalcat(inv, category_114) = 0 & inv_totalcat(inv, category_115) = 0) {
        mes("You need a key to open this door.");
        return;
    }
}
@catacombs_open_door($entering);

[oploc1,shadelair_blackdoor]
def_boolean $entering = ~check_axis(coord, loc_coord, loc_angle);
if($entering = true) {
    if(inv_totalcat(inv, category_114) = 0 & inv_totalcat(inv, category_115) = 0) {
        mes("You need a key to open this door.");
        return;
    }
}
@catacombs_open_door($entering);

[oploc1,shadelair_silverdoor]
def_boolean $entering = ~check_axis(coord, loc_coord, loc_angle);
if($entering = true) {
    if(inv_totalcat(inv, category_115) = 0) {
        mes("You need a key to open this door.");
        return;
    }
}
@catacombs_open_door($entering);

[label,catacombs_open_door](boolean $entering)
if($entering = true) {
    mes("You open the ominous tomb door.");
} else {
    mes("You walk back through the ominous door.");
}
~open_and_close_metal_gate(shadelair_doorinac, $entering, false); // uses grate sound

[label,catacombs_exit]
p_arrivedelay;
p_walk(0_54_151_37_62);
p_delay(0);
mes("You make your way back out of the Shade tombs.");
p_teleport(0_54_51_29_58);

[proc,get_shadekeys_total]()(int)
def_int $total = 0;
$total = add($total, inv_totalcat(inv, category_112)); //bronze
$total = add($total, inv_totalcat(inv, category_113)); //steel
$total = add($total, inv_totalcat(inv, category_114)); //black
$total = add($total, inv_totalcat(inv, category_115)); //silver
return ($total);

[oploc1,shadechest_bronze_bloodred]
if (inv_total(inv, shadekey_bronze_bloodred) = 0) {
    mes("You don't have the correct key.");
    mes("You need a bronze key with a red trim to open this chest.");
    sound_synth(locked, 1, 0);
    return;
}
inv_del(inv, shadekey_bronze_bloodred, 1);
@open_shade_chest(^bronze_shadechest, ^red_shadekey);

[oplocu,shadechest_bronze_bloodred]
def_obj $item = last_useitem;
if (oc_category($item) = category_112 | oc_category($item) = category_113 | oc_category($item) = category_114 | oc_category($item) = category_115) {
    if ($item ! shadekey_bronze_bloodred) {
        mes("You need a bronze key with a red trim to open this chest.");
        sound_synth(locked, 1, 0);
        return;
    }
    inv_del(inv, shadekey_bronze_bloodred, 1);
    @open_shade_chest(^bronze_shadechest, ^red_shadekey);
}
~displaymessage(^dm_default);

