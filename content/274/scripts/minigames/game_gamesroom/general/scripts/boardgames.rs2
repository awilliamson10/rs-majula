[proc,calculate_rank_change](int $loser, int $winner)(int)
def_int $rank_change = add(50, divide(sub($loser, $winner), 16));

if($rank_change > 100) {
    $rank_change = 100;
} else if ($rank_change < 1) {
    $rank_change = 1;
}

return ($rank_change);

[if_close,boardgames_challenge]
if (%boardgames_closinginterface = 0) {
    %duel2accept = null;
    ~reset_boardgames_varp;
}

[softtimer,boardgames_sitting_anim]
if (%boardgames_myturn = 0) {
    return;
} else {
    //50% chance of either one
    if (random(2) = 0) {
        anim(human_sittingdown_think, 0);
    } else {
        anim(human_sittingdown_scratch, 0);
    }
    //Every 5-9 ticks from osrs
    softtimer(boardgames_sitting_anim, ~random_range(5,9));
}

[proc,boardgames_table_setup]
def_coord $current_table_coord;
def_int $current_table;

$current_table_coord, $current_table = ~find_next_boardgames_table;

if($current_table_coord = null) {
    //There's probably a mes for this? Guess
    mes("All tables are currently full!");
    return;
}

if(loc_find(~get_boardgames_table_coord($current_table), boardgames_table) = false) {
    return;
}

if (.p_finduid(%duel2accept) = false) {
    mes("That player is no longer available.");
    return;
}

%boardgames_tablenum = $current_table;
.%boardgames_tablenum = $current_table;

if(loc_shape = centrepiece_straight) {
    if(loc_angle = ^loc_south) {
    p_telejump(movecoord(loc_coord, -1, 0, 0));
    .p_telejump(movecoord(loc_coord, 1, 0, 0));
    } else if(loc_angle = ^loc_north) {
    p_telejump(movecoord(loc_coord, 1, 0, 0));
    .p_telejump(movecoord(loc_coord, -1, 0, 0));
    } else if(loc_angle = ^loc_east) {
    p_telejump(movecoord(loc_coord, 0, 0, -1));
    .p_telejump(movecoord(loc_coord, 0, 0, 1));
    } else {
    p_telejump(movecoord(loc_coord, 0, 0, 1));
    .p_telejump(movecoord(loc_coord, 0, 0, -1));
    }
} else {
    if(loc_angle = ^loc_east) {
        p_telejump(movecoord(loc_coord, -1, 0, -1));
        .p_telejump(movecoord(loc_coord, 1, 0, 1));
    } else if(loc_angle = ^loc_south) {
        p_telejump(movecoord(loc_coord, -1, 0, 1));
        .p_telejump(movecoord(loc_coord, 1, 0, -1));
    } else if(loc_angle = ^loc_north) {
        p_telejump(movecoord(loc_coord, 1, 0, -1));
        .p_telejump(movecoord(loc_coord, -1, 0, 1));
    } else {
        p_telejump(movecoord(loc_coord, 1, 0, 1));
        .p_telejump(movecoord(loc_coord, -1, 0, -1));
    }
}

facesquare(.coord);
.facesquare(coord);

loc_change(~get_boardgames_table, ^max_32bit_int);

if(loc_find(coord, boardgames_barstool_white) = true) {
    loc_change(boardgames_barstool_invis, ^max_32bit_int);
}

if(loc_find(.coord, boardgames_barstool_white) = true) {
    loc_change(boardgames_barstool_invis, ^max_32bit_int);
}

anim(human_sittingdown_ready, 0);
.anim(human_sittingdown_ready, 0);

//Todo: Figure out the exact seating order
[proc,get_boardgames_table_coord](int $tablenum)(coord)
if($tablenum > 47) {
    return (~get_boardgames_table_coord_upstairs($tablenum));
} else {
    return (~get_boardgames_table_coord_downstairs($tablenum));
}

[proc,get_boardgames_table_coord_downstairs](int $tablenum)(coord)
def_int $x = 0;
def_int $z = 0;
def_int $quadrant = divide($tablenum, 12);
def_int $local_table = modulo($tablenum, 12);
def_int $row = 0;
def_int $col = 0;

if ($local_table < 4) {
    $row = 0;
    $col = $local_table;
} else if ($local_table < 7) {
    $row = sub($local_table, 3);
    $col = 3;
} else if ($local_table < 10) {
    $row = 3;
    $col = modulo($local_table, 9);
} else {
    $row = modulo($local_table, 12);
    $col = 0;
}

if($row = 0) {
$z = 20;
} else if($row = 1) {
$z = 23;
} else if($row = 2) {
$z = 25;
} else {
$z = 28;
}

if($col = 0) {
$x = 20;
} else if($col = 1) {
$x = 23;
} else if($col = 2) {
$x = 25;
} else {
$x = 28;
}

if($quadrant = 1) {
    $x = add($x, 15);
} else if($quadrant = 2) {
    $x = add($x, 15);
    $z = add($z, 15);
} else if($quadrant = 3) {
    $z = add($z, 15);
}

return (movecoord(0_34_77_0_0, $x, 0, $z));

[proc,get_boardgames_table_coord_upstairs](int $tablenum)(coord)
$tablenum = sub($tablenum, 48);

def_int $local_table = modulo($tablenum, 12);
def_int $quadrant = divide($tablenum, 12);
def_int $x = 0;
def_int $z = 0;

switch_int ($local_table) {
    case 0 : $x = 18; $z = 29;
    case 1 : $x = 19; $z = 19;
    case 2 : $x = 20; $z = 24;
    case 3 : $x = 20; $z = 26;
    case 4 : $x = 20; $z = 29;
    case 5 : $x = 21; $z = 21;
    case 6 : $x = 22; $z = 29;
    case 7 : $x = 24; $z = 20;
    case 8 : $x = 26; $z = 20;
    case 9 : $x = 29; $z = 18;
    case 10 : $x = 29; $z = 20;
    case 11 : $x = 29; $z = 22;
}

if ($quadrant = 1) { 
    $x = sub(63, $x);
} else if ($quadrant = 2) { 
    $x = sub(63, $x);
    $z = sub(63, $z);
} else if ($quadrant = 3) { 
    $z = sub(63, $z);
}

return (movecoord(1_34_77_0_0, $x, 0, $z));

[proc,find_next_boardgames_table]()(coord, int)
def_int $i = 0;
if(%boardgames_challengeroom = 1) {
    $i = add($i, 48);
}

def_int $max = add($i, 48);
while ($i < $max) {
    def_coord $check_coord = ~get_boardgames_table_coord($i);
    if (loc_find($check_coord, boardgames_table) = true) {
        return ($check_coord, $i);
    }
    $i = add($i, 1);
}
return (null, -1);

[proc,get_boardgames_table]()(loc)
switch_int (%boardgames_game) {
    case 0 : return (boardgames_table_draughts);
    case 1 : return (boardgames_table_runelink);
    // case 2 : return (boardgames_table_runesquares);
    // case 3 : return (boardgames_table_runeversi);
}

