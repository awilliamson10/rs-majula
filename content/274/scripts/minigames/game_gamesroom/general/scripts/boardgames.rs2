[proc,get_sandtimer_seq]()(seq)
switch_int (%boardgames_timepermove) {
    case 0 : return (sandtimer_15secs);
    case 1 : return (sandtimer_30secs);
    case 2 : return (sandtimer_60secs);
    case 3 : return (sandtimer_120secs);
}

[proc,get_sandtimer_interval]()(int)
switch_int (%boardgames_timepermove) {
    case 0 : return (25);
    case 1 : return (50);
    case 2 : return (100);
    case 3 : return (200);
}

[proc,get_boardgames_timepermove]()(string)
switch_int (%boardgames_timepermove) {
    case 0 : return ("15 seconds");
    case 1 : return ("30 seconds");
    case 2 : return ("1 minute");
    case 3 : return ("2 minutes");
}

[proc,get_boardgames_game]()(string)
switch_int (%boardgames_game) {
    case 0 : return ("Draughts");
    case 1 : return ("Runelink");
    // case 2 : return ("Runesquares");
    // case 3 : return ("Runeversi");
}

