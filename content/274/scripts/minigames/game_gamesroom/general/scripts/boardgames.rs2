[proc,set_boardgames_timepermove](int $time)
if (.finduid(%duel2accept) = false) {
    mes("That player is no longer available.");
    if_close;
    return;
}
if(.%duel2accept = uid) {
    mes("You can not change the time per move when accepting a challenge.");
} else {
    %boardgames_timepermove = $time;
}

[proc,set_boardgames_piece](int $piece)
if (.finduid(%duel2accept) = false) {
    mes("That player is no longer available.");
    if_close;
    return;    
}
if(.%duel2accept = uid & .%boardgames_piece = $piece) {
    mes("Your opponent is using this piece, please choose another.");
} else {
    %boardgames_piece = $piece;
}

[proc,toggle_boardgames_ranked]
if (.finduid(%duel2accept) = false) {
    mes("That player is no longer available.");
    if_close;
    return;    
}
if(.%duel2accept = uid) {
    mes("You can not change the ranked option when accepting a challenge.");
} else {
    if (%boardgames_rankedgame = ^false) {
        %boardgames_rankedgame = ^true;
    } else {
        %boardgames_rankedgame = ^false;
    }
}

[proc,reset_boardgames_varp]
%boardgames_varbit = 0;
%boardgames_varbit2 = 0;

[proc,boardgames_hide_tabs]
if_settab(null, 0);
if_settab(null, 1);
if_settab(null, 2);
if_settab(null, 3);
if_settab(null, 4);
if_settab(null, 5);
if_settab(null, 6);
if_settab(null, 11);
if_settab(null, 12);

[proc,.boardgames_hide_tabs]
if (.p_finduid(.uid) = true) {
    .if_settab(null, 0);
    .if_settab(null, 1);
    .if_settab(null, 2);
    .if_settab(null, 3);
    .if_settab(null, 4);
    .if_settab(null, 5);
    .if_settab(null, 6);
    .if_settab(null, 11);
    .if_settab(null, 12);
}

[mapzone,0_34_77]
//set varps on first time entering
if(%boardgames_draughts_rank < 1) {
    %boardgames_draughts_rank = 1000;
}
if(%boardgames_runelink_rank < 1) {
    %boardgames_runelink_rank = 1000;
}
set_player_op("Challenge", 1, ^false);
@music_playbyregion(coord);

[mapzoneexit,0_34_77]
~reset_boardgames_varp;
set_player_op(null, 1, ^false);

[proc,in_games_room](coord $coord)(boolean)
if (~inzone_coord_pair_table(games_room_zones, $coord) = true) {
    return(true);
}
return(false);

