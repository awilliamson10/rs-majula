[levelup_attack]
table=levelup
data=stat,attack
data=interface,levelup_attack
data=title,levelup_attack:line1
data=body,levelup_attack:line2
data=message,"Congratulations, you just advanced an attack level."
data=level_prefix,Your attack level is now
data=levelup_jingle,advance attack
data=unlocks_jingle,advance attack2
data=unlocks_levels,levelup_unlocks_attack

