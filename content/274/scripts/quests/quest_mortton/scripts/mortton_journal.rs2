// https://youtu.be/WIzjtcXkv7M?si=Om_geSsyfYgbpXNv&t=125
[if_button,questlist:mortton]
def_string $text;

if(%morttonquest = 0) {
    $text = "@dbl@I can start this quest by exploring the town of @dre@Mort'ton@dbl@ which is accessible from the southern edge of @dre@Mort Myre@dbl@.";
    ~quest_journal("Shades of Mort'ton", $text);
    return;
} else if (%morttonquest = ^mortton_quest_complete) {
    $text = "@str@I travelled to the town of Mort'ton where the people had an|@str@affliction. I found the diary of 'Herbi Flax' and managed to|@str@work out the ingredients for a special serum. The serum|@str@worked on the afflicted and I was able to speak to several|@str@villagers.|@str@After slaying five shades and helping to rebuild a sacred|@str@temple, I was able to put the shades spirits to rest. The|@str@town has pretty much returned to normal, except for all the|@str@shade activity, but now I have a way to put the shades|@str@spirits to rest and gain access to their treasure filled lairs!|";
    $text = append($text, "@red@QUEST COMPLETE!"); 
    ~quest_journal("Shades of Mort'ton", $text);
    return;
}
if(%morttonquest >= ^mortton_read_diary) {
    $text = "@str@I can start this quest by exploring the town of Mort'ton|@str@which is accessible from the southern edge of Mort Myre.|";
} 
if (%morttonquest >= ^mortton_made_serum) {
    $text = append($text, "@str@I made my way down through Mort Myre and found the town|@str@of Mort'ton. I discovered a diary which had some notes on|@str@a special serum in it. I made the serum.|");
}
if (%morttonquest >= ^mortton_kill_shades) {
    $text = append($text, "@str@I made serum 207 from tarromin, water and ashes by using|@str@Herbi Flax's diary. I wonder what the serum is used for?|");
    $text = append($text, "@str@I used the serum on a local NPC and I've been able to ask|@str@a few questions about the place.|");
    if (%morttonquest = ^mortton_kill_shades) {
        $text = append($text, "@dbl@I talked to @dre@Razmire Keelgan@dbl@ and he asked me to kill @dre@five shades@dbl@ for him. He seems to hate them!|");
    } else {
        $text = append($text, "@str@I talked to Razmire Keelgan and he asked me to kill five|@str@shades for him. He seems to hate them!|");
    }
}
if (%morttonquest >= ^mortton_shades_to_razmire) {
    $text = append($text, "@str@I've killed five shades and showed the remains to Razmire.|");
    $text = append($text, "@str@Razmire told me to show the remains to Ulsquire.|");
}
if (%morttonquest >= ^mortton_shades_to_ulsquire) {
    $text = append($text, "@str@I showed Ulsquire the shade remains and he gave me some|@str@information which may be useful.|");
}
if (%morttonquest >= ^mortton_rebuild_temple) {
    $text = append($text, "@str@Ulsquire seems to know a lot about this area, he's quite|@str@interested in 'Flaemtaer temple' and wishes he could|@str@rebuild it.|");
}
if (%morttonquest >= ^mortton_can_light_altar) {
    //Replaced timber beams with wooden planks (guess)
    $text = append($text, "@str@I helped rebuild the temple using limestone bricks, wooden|@str@planks and nails.|");
}
if (%morttonquest >= ^mortton_created_sacred_oil) {
    $text = append($text, "@str@When all of the temple walls were rebuilt, a fire altar|@str@appeared. The flame from the altar was sacred.|@str@I placed a flask of olive oil in the flame and it became|@str@sacred oil.|");
}
if (%morttonquest >= ^mortton_created_pyre_logs) {
    $text = append($text, "@str@I used sacred oil on logs turning them into pyre logs.|");
}
if (%morttonquest >= ^mortton_logs_on_pyre) {
    $text = append($text, "@str@I placed some pyre logs onto a funeral pyre.|");
}
if (%morttonquest >= ^mortton_lit_pyre) {
    $text = append($text, "@str@I placed the shade remains on the pyre and set it on fire in|@str@order to put the Shades to rest.|");
}

if(%morttonquest = ^mortton_read_diary) {
    $text = append($text,"@dbl@I made my way down through @dre@Mort Myre@dbl@ and I found the town of @dre@Mort'ton@dbl@. ");
    if (inv_total(inv, serum_book) = 0 & inv_total(bank, serum_book) = 0) {
        $text = append($text, "I discovered a @dre@diary@dbl@ which had some interesting @dre@notes@dbl@ in it. @dbl@Maybe it was important?");
    } else if (inv_total(bank, serum_book) > 0) {
        $text = append($text, "I discovered a @dre@diary@dbl@ which had some interesting @dre@notes@dbl@ in it, I placed the book in my @dre@bank@dbl@.");
    } else {
        $text = append($text, "I've found a @dre@diary@dbl@ which has some interesting @dre@notes@dbl@ in it. Perhaps this can help me?");
    }
}
if(%morttonquest = ^mortton_made_serum) {
    if (testbit(%morttonmulti, ^mortton_used_serum_on_razmire) = ^true | testbit(%morttonmulti, ^mortton_used_serum_on_ulsquire) = ^true) {
        $text = append($text, "@str@I made serum 207 from tarromin, water and ashes by|@str@using Herbi Flax's diary. I wonder what the serum is used|@str@for?|");
        $text = append($text, "@dbl@I used the @dre@serum@dbl@ on a local NPC and I've been able to ask a few questions about the place.");
    } else {
        $text = append($text, "@dbl@I made @dre@serum 207@dbl@ from tarromin, water and ashes by using @dre@Herbi Flax's@dbl@ diary. I wonder what the @dre@serum@dbl@ is used for?");
    }
}

if (%morttonquest = ^mortton_kill_shades) {
    $text = append($text, "@dbl@I have to kill @dre@five@dbl@ shades.");
} else if (%morttonquest = ^mortton_killed_1_shade) {
    $text = append($text, "@dbl@I've killed @dre@one@dbl@ shade, I need to kill another @dre@four@dbl@.");
} else if (%morttonquest = ^mortton_killed_2_shades) {
    $text = append($text, "@dbl@I've killed @dre@two@dbl@ shades, I need to kill another @dre@three@dbl@.");
} else if (%morttonquest = ^mortton_killed_3_shades) {
    $text = append($text, "@dbl@I've killed @dre@three@dbl@ shades, I need to kill another @dre@two@dbl@.");
} else if (%morttonquest = ^mortton_killed_4_shades) {
    $text = append($text, "@dbl@I've killed @dre@four@dbl@ shades, I need to kill another @dre@one@dbl@.");
} else if (%morttonquest = ^mortton_killed_5_shades) {
    $text = append($text, "@dbl@I've killed all @dre@five shades@dbl@, I should return to @dre@Razmire@dbl@ now.");
}

if (%morttonquest = ^mortton_shades_to_razmire) {
    $text = append($text, "@dbl@I should show the @dre@shade@dbl@ remains to @dre@Ulsquire@dbl@.");
}

if (%morttonquest = ^mortton_shades_to_ulsquire) {
    $text = append($text, "@dre@Ulsquire@dbl@ seems to know a lot about this area, maybe if I @dre@investigate@dbl@ around here a little more I can help the locals.");
}

if (%morttonquest = ^mortton_ulsquire_temple) {
    $text = append($text, "@dre@Ulsquire@dbl@ seems to know a lot about this area, he's quite interested in @dre@'Flaemtaer temple'@dbl@ and wishes he could rebuild it.");
}

if (%morttonquest = ^mortton_rebuild_temple) {
    $text = append($text, "@dbl@I've started @dre@rebuilding@dbl@ the @dre@temple@dbl@ using @dre@limestone bricks@dbl@, @dre@wooden planks@dbl@ and @dre@nails@dbl@. I wonder what @dre@power@dbl@ the @dre@temple@dbl@ has, if any?|");
    if (inv_totalcat(inv, category_110) > 0) {
        $text = append($text, "@dbl@I have some @dre@olive oil@dbl@ which @dre@Ulsquire@dbl@ said may be useful when the @dre@temple@dbl@ is constructed.");
    }
}

if (%morttonquest = ^mortton_can_light_altar) {
    $text = append($text, "@dbl@There must be some way to make use of the @dre@altar@dbl@ that appears in the @dre@middle@dbl@ of the @dre@temple@dbl@.");
}

if (%morttonquest = ^mortton_created_sacred_oil) {
    $text = append($text, "@dre@Ulsquire@dbl@ said something about putting the @dre@Shades@dbl@ to rest by giving them a @dre@holy cremation@dbl@, maybe this @dre@oil@dbl@ can help?");
}

if (%morttonquest = ^mortton_created_pyre_logs) {
    def_int $shade_count = inv_totalcat(inv, category_2049);
    def_int $pyre_log_count = inv_totalcat(inv, category_2050);
    if($shade_count = 0 & $pyre_log_count = 0) {
        $text = append($text, "@dbl@Maybe the @dre@pyre logs@dbl@ are connected to the @dre@Shade@dbl@ remains?|");        
    } else if($shade_count > 0 & $pyre_log_count = 0) {
        $text = append($text, "@dbl@I have some @dre@Shade@dbl@ remains, I need to find a way to put its @dre@spirit@dbl@ to rest.");
    } else if($shade_count = 0 & $pyre_log_count > 0) {
        $text = append($text, "@dbl@I have some @dre@pyre logs@dbl@, perhaps I can use these somehow to put a @dre@Shades spirit@dbl@ to rest.");
    } else {
        $text = append($text, "@str@Maybe the pyre logs are connected to the Shade remains?|");
        $text = append($text, "@dbl@I have some @dre@Shade@dbl@ remains and I have some @dre@pyre logs@dbl@, I can now try to put a @dre@shades@dbl@ spirit to rest.");
    }
}

if (%morttonquest = ^mortton_logs_on_pyre) {
    $text = append($text, "@dbl@I need to put the @dre@shade remains@dbl@ on the @dre@funeral pyre@dbl@ and then @dre@light@dbl@ it in order to put the@dre@ shade spirit@dbl@ to rest.");
}

if (%morttonquest = ^mortton_lit_pyre) {
    $text = append($text, "@dbl@The @dre@shades spirit@dbl@ was released, I should tell @dre@Ulsquire@dbl@.");
}

~quest_journal("Shades of Mort'ton", $text);
