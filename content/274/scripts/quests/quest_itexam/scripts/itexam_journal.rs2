[if_button,questlist:itexam]
def_string $x;
def_string $n = "The Dig Site";

if (%itexamlevel = ^itexam_not_started) {
    $x = "@dbl@I can start this quest by speaking to the @dre@Examiner @dbl@at the @dre@Digsite Exam Centre.|";

    $x = append($x, "|@dbl@To complete this quest I need:|");

    if (stat_base(agility) >= 10) {
        $x = append($x, "@str@Level 10 Agility|");
    } else {
        $x = append($x, "@dre@Level 10 Agility|");
    }

    if (stat_base(herblore) >= 10) {
        $x = append($x, "@str@Level 10 Herblore|");
    } else {
        $x = append($x, "@dre@Level 10 Herblore|");
    }

    if (stat_base(thieving) >= 25) {
        $x = append($x, "@str@Level 25 Thieving|");
    } else {
        $x = append($x, "@dre@Level 25 Thieving|");
    }

    ~quest_journal($n, $x);
    return;
}

def_int $progress = ~itexam_progress;

$x = "@str@I should speak to the Examiner about taking Earth|@str@Science Exams.|";

if ($progress > ^itexam_stamping) {
    $x = append($x, "|@str@I should take the letter the Examiner has given me|@str@to the Curator of the Varrock Museum for his approval.|");
    $x = append($x, "|@str@I need to return the letter of recommendation from the|@str@Curator of Varrock Museum, to the Examiner at the|@str@Exam Centre for inspection.|");
} else if ($progress = ^itexam_stamping) {
    // we don't use any bits set specifying that the letter was stamped
    if (inv_total(inv, recommendedletter) > 0) {
        $x = append($x, "|@str@I should take the letter the Examiner has given me|@str@to the Curator of the Varrock Museum for his approval.|");
        $x = append($x, "|@dbl@I need to return the @dre@letter of recommendation @dbl@from the @dre@Curator of Varrock Museum@dbl@, to the @dre@Examiner @dbl@at the|@dbl@Exam Centre for inspection.|");
    } else {
        $x = append($x, "|@dbl@I should take the @dre@letter @dbl@the @dre@Examiner @dbl@has given me to the @dre@Curator of the Varrock Museum @dbl@for his approval.");
    }
}

// todo: find more sources for the exam step texts, line breaks and spacing especially
// todo: we only have 50 quest journal lines to work with so I'm consolidating each exam to "I have passed" when completed
//       unless we find a better source. 377 has 100 quest journal lines.

if ($progress > ^itexam_first_exam) {
    $x = append($x, "|@str@I have passed my first Earth Science exam.|");
} else if ($progress = ^itexam_first_exam) {
    $x = append($x, "|@dbl@I need to study for my first exam. Perhaps the @dre@students @dbl@on the digsite can help?|");

    def_int $errand1 = ~itexam_errand_progress(^itexam_errand_student1);
    def_int $errand2 = ~itexam_errand_progress(^itexam_errand_student2);
    def_int $errand3 = ~itexam_errand_progress(^itexam_errand_student3);

    if ($errand1 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the green top about the|@str@exams.");
        $x = append($x, "|@str@He gave me an answer to one of the questions on the first|@str@exam.");
    } else if ($errand1 = ^itexam_errand_started) {
        $x = append($x, "|@str@I need to speak to the student in the green top about the|@str@exams.");

        if (inv_total(inv, rock_sample1) > 0) {
            $x = append($x, "|@str@I have agreed to help the student in the green top.");
            $x = append($x, "|@str@He has lost his rock sample and thinks he may have|@str@dropped it around the digsite.|@str@I need to find it and return it to him.");

            $x = append($x, "|@dbl@I should talk to him to see if he can help with any exams.");
        } else {
            $x = append($x, "|@dbl@I have agreed to help the student in the green top.|");
            $x = append($x, "He has lost his rock sample and thinks he may have dropped it around the digsite.|I need to find it and return it to him.");
        }
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the green top about the exams.");
    }

    if ($errand2 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the purple shirt about|@str@the exams.");
        $x = append($x, "|@str@She gave me an answer to one of the questions on the|@str@first exam.");
    } else if ($errand2 = ^itexam_errand_started) {
        $x = append($x, "|@str@I need to speak to the student in the purple shirt about|@str@the exams.");

        if (inv_total(inv, rock_sample3) > 0) {
            $x = append($x, "|@str@I agreed to help the student in the purple shirt.");
            $x = append($x, "|@str@She has lost her rock sample and thinks she may have|@str|dropped it in a bush. I need to find it and return it to her.");

            $x = append($x, "|@dbl@I should talk to her to see if she can help with any exams.");
        } else {
            $x = append($x, "|@dbl@I agreed to help the student in the purple shirt.");
            $x = append($x, "|She has lost her rock sample and thinks she may have dropped it in a bush. I need to find it and return it to her.");
        }
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the purple shirt about the exams.");
    }

    if ($errand3 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the orange top about the|@str@exams.");
        $x = append($x, "|@str@He gave me an answer to one of the questions on the first|@str@exam.");
    } else if ($errand3 = ^itexam_errand_started) {
        $x = append($x, "|@str@I need to speak to the student in the orange top about the|@str@exams.");

        if (inv_total(inv, rock_sample2) > 0) {
            $x = append($x, "|@str@I have agreed to help the student in the orange top.");
            $x = append($x, "|@str@He has lost his rock sample and thinks he may have|@str@dropped it in the water.|@str@I need to find it and return it to him.");

            $x = append($x, "|@dbl@I should talk to him to see if he can help with any exams.");
        } else {
            $x = append($x, "|@dbl@I have agreed to help the student in the orange top.");
            $x = append($x, "|He has lost his rock sample and thinks he may have dropped it in the water.|I need to find it and return it to him.");
        }
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the orange top about the exams.");
    }

    if ($errand1 = ^itexam_errand_answered & $errand2 = ^itexam_errand_answered & $errand3 = ^itexam_errand_answered) {
        $x = append($x, "|@dbl@I should talk to the Examiner to take my first exam. If I have forgotten anything I can always ask the students again.");
    }
}

if ($progress > ^itexam_second_exam) {
    $x = append($x, "|@str@I have passed my second Earth Science exam.|");
} else if ($progress = ^itexam_second_exam) {
    $x = append($x, "|@dbl@I need to study for my second exam. Perhaps the three students on the digsite can help me again?|");

    def_int $errand1 = ~itexam_errand_progress(^itexam_errand_student1);
    def_int $errand2 = ~itexam_errand_progress(^itexam_errand_student2);
    def_int $errand3 = ~itexam_errand_progress(^itexam_errand_student3);

    if ($errand1 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the green top about the|@str@exams.");
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the green top about the exams.");
    }

    if ($errand2 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the purple shirt about|@str@the exams.");
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the purple shirt about the exams.");
    }

    if ($errand3 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the orange top about the|@str@exams.");
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the orange top about the exams.");
    }

    if ($errand1 = ^itexam_errand_answered & $errand2 = ^itexam_errand_answered & $errand3 = ^itexam_errand_answered) {
        $x = append($x, "|@dbl@I should talk to the Examiner to take my second exam. If I have forgotten anything I can always ask the students again.");
    }
}

if ($progress > ^itexam_third_exam) {
    $x = append($x, "|@str@I have passed my third Earth Science exam.|");
} else if ($progress = ^itexam_third_exam) {
    $x = append($x, "|@dbl@I need to study for my third exam. Perhaps the three students on the digsite can help me again?|");

    def_int $errand1 = ~itexam_errand_progress(^itexam_errand_student1);
    def_int $errand2 = ~itexam_errand_progress(^itexam_errand_student2);
    def_int $errand3 = ~itexam_errand_progress(^itexam_errand_student3);

    if ($errand1 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the green top about the|@str@exams.");
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the green top about the exams.");
    }

    if ($errand2 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the purple shirt about|@str@the exams.");
    } else if ($errand2 = ^itexam_errand_started) {
        $x = append($x, "|@str@I need to speak to the student in the purple shirt about|@str@the exams.");
        $x = append($x, "|@dbl@I need to bring her an opal.");
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the purple shirt about the exams.");
    }

    if ($errand3 = ^itexam_errand_answered) {
        $x = append($x, "|@str@I need to speak to the student in the orange top about the|@str@exams.");
    } else {
        $x = append($x, "|@dbl@I need to speak to the student in the orange top about the exams.");
    }

    if ($errand1 = ^itexam_errand_answered & $errand2 = ^itexam_errand_answered & $errand3 = ^itexam_errand_answered) {
        $x = append($x, "|@dbl@I should talk to the Examiner to take my third exam. If I have forgotten anything I can always ask the students again.");
    }
}

if ($progress > ^itexam_impress_archeological_expert) {
    // todo: this is the RS3 text minus the expert's name
    $x = append($x, "|@str@I need a find from the site to impress the archeological|@str@expert at the Exam Centre.");
    $x = append($x, "|@str@I need to take the letter to a workman near a winch.|");
} else if ($progress = ^itexam_impress_archeological_expert) {
    // todo: this is the RS3 text minus the expert's name
    $x = append($x, "|@dbl@I need a find from the site to impress the @dre@archeological expert at the Exam Centre.");
    $x = append($x, "|@dbl@I need to take the @dre@letter @dbl@to a workman near a @dre@winch.");
}

if ($progress > ^itexam_mineshaft_permit) {
    $x = append($x, "|@str@I need to investigate the dig shafts.");
    $x = append($x, "|@str@I need to find a way to move the rocks blocking the way|@str@in the shaft. Perhaps someone else in these dig shafts|@str@can help me.|");
} else if ($progress = ^itexam_mineshaft_permit) {
    $x = append($x, "|@dbl@I need to @dre@investigate the dig shafts.");
    $x = append($x, "|@dbl@I need to find a way to move the rocks blocking the way in the shaft. Perhaps someone else in these dig shafts can help me.");
}

if ($progress > ^itexam_poured_compound_on_bricks) {
    $x = append($x, "|@str@I covered the rocks in the cave with an explosive compound.|");
    $x = append($x, "|@str@I need to ignite the explosive compound and blow up the|@str@rocks blocking the way.|");
} else if ($progress = ^itexam_poured_compound_on_bricks) {
    $x = append($x, "|@str@I covered the rocks in the cave with an explosive compound.|");
    $x = append($x, "|@dbl@I need to ignite the explosive compound and blow up the rocks blocking the way.");
}

if ($progress > ^itexam_removed_blockage) {
    // todo: this is the RS3 text minus the expert's name
    $x = append($x, "|@str@I should look for an interesting find in the secret room I|@str@found, and show it to the archeological expert|@str@at the Exam Centre.|");
} else if ($progress = ^itexam_removed_blockage) {
    // todo: this is the RS3 text minus the expert's name
    $x = append($x, "|@dbl@I should look for an interesting find in the secret room I found, and show it to @dre@the archeological expert@dbl@ at the Exam Centre.");
}

if ($progress = ^itexam_complete) {
    $x = append($x, "|@str@The expert was impressed with the Zarosian tablet that I|@str@found, and I also discovered an ancient altar!");
    $x = append($x, "|@str@I was rewarded for my findings.");
    $x = append($x, "|@str@My work here is done.");
    $x = append($x, "|@dbl@I should also talk to the expert about any other finds."); // todo: could be a later addition
    $x = append($x, "|@red@QUEST COMPLETE!");
}

~quest_journal($n, $x);
