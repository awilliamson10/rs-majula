[label,eadgar_quest_dialog]
switch_int(%eadgar_quest) {
    case ^eadgar_started : @eadgar_quest_initial_tree;
    case ^eadgar_spoken_eadgar_first, ^eadgar_spoken_burntmeat_second : @eadgar_talked_to_troll_cook;
    case ^eadgar_spoken_burntmeat_first : @eadgar_need_goutweed; // dialog jumps straight here if the player talks to burntmeat first
    case ^eadgar_needs_parrot : @eadgar_got_parrot_yet;
    case ^eadgar_explained_plan : @eadgar_hasnt_hidden_parrot;
    case ^eadgar_hid_parrot : @eadgar_hid_parrot;
    case ^eadgar_needs_items : @eadgar_how_are_you_getting_on;
    case ^eadgar_needs_potion : @eadgar_got_troll_truth_potion;
    case ^eadgar_needs_parrot_back : @eadgar_needs_parrot_back;
    case ^eadgar_got_parrot_back : @eadgar_got_parrot_back;
    case ^eadgar_got_fake_man : @eadgar_given_fake_man_yet;
    case ^eadgar_got_burnt_meat, ^eadgar_unlocked_storeroom : @eadgar_did_the_plan_work; // In RS3 this dialog is available after getting the burnt meat / In OSRS it's available after unlocking the storeroom
    // I haven't checked the inverse for either game yet but for now I'm assuming behavior is the same and the dialog should be available during both quest stages (minor TODO I guess)
}

[label,eadgar_quest_initial_tree]
switch_int(~p_choice4("I need to find some goutweed.", 1, "Why do you live so close to the trolls?", 2, "What do you have to offer?", 3, "No thanks, Eadgar.", 4)) {
    case 1 : @eadgar_need_goutweed;
    case 2 : @eadgar_live_so_close;
    case 3 : @eadgar_what_do_you_have;
    case 4 : @eadgar_nothanks;
}

[label,eadgar_anything_else_default_tree]
// mesanim rsprox/indio, this line is always <p,neutral>
~chatnpc("<p,neutral>Anything else I can do for you?");
@eadgar_default_tree;

[label,eadgar_need_goutweed]
// dialog source https://youtu.be/tEsRQ9fXIU?t=150
// mesanims rsprox/branon
~chatplayer("<p,neutral>I need to find some goutweed. Sanfew said you might be able to help.");
~chatnpc("<p,quiz>Sanfew, you say? Ah, haven't seen him in a while...");
if(%eadgar_quest = ^eadgar_spoken_burntmeat_first) {
    @eadgar_talked_to_troll_cook;
} else {
    @eadgar_goutweed_advice;
}

[label,eadgar_goutweed_advice]
// rsprox/indio
~chatnpc("<p,neutral>Goutweed is used as an ingredient in troll cooking. You should ask one of their cooks.");
%eadgar_quest = ^eadgar_spoken_eadgar_first;

[label,eadgar_talked_to_troll_cook]
if(%eadgar_quest = ^eadgar_spoken_eadgar_first) { // this is only used if the player goes to eadgar first after sanfew
    // mesanim rsprox/indio
    ~chatnpc("<p,neutral>Oh, it's you. Have you talked to the troll cook yet?");
}
if(%eadgar_quest = ^eadgar_spoken_burntmeat_first | %eadgar_quest = ^eadgar_spoken_burntmeat_second) { // this dialog is used if burntmeat has been spoken to at all, regardless of order
    // rsprox/branon
    ~chatplayer("<p,sad>I talked to the troll cook but he wouldn't tell me anything, and now he wants me to find him some tasty human for his stew.");
    ~chatnpc("<p,sad>Oh dear, that's no good. You can't just go hand over a human to those trolls...");
    ~chatnpc("<p,happy>Aha! I have a plan!");
    ~chatplayer("<p,happy>Really?");
    %eadgar_quest = ^eadgar_needs_parrot; 
    ~chatnpc("<p,happy>Yes! It's bound to work. First of all, I will need a parrot!");
    ~chatplayer("<p,confused>A PARROT? Where am I going to find one of those?");
    ~chatnpc("<p,happy>At the zoo, where else?");
} else {
    // mesanim rsprox/indio
    ~chatplayer("<p,neutral>Not yet.");
    ~chatnpc("<p,neutral>Well, you should do that then.");
}
@eadgar_anything_else_default_tree;

[label,eadgar_got_parrot_yet]
// rsprox/branon
~chatnpc("<p,neutral>Oh, it's you. Have you got me a parrot yet?");
if(inv_total(inv, eadgar_drunk_parrot) > 0) {
    ~chatnpc_specific("Parrot", eadgar_parrotts, "<p,neutral>Raaawk! Polly wanna cracker!");
    ~chatplayer("<p,happy>Here it is! How are you going to explain your plan?");
    ~chatnpc("<p,happy>Yes, yes, of course. It's quite ingenious really!");
    ~chatnpc("<p,neutral>What we need is something that looks like a human,|sounds like a human, smells like a human and tastes|like a human."); //linebreaks from from runeweb, one of the few 2004-era images we have of this quest
    ~chatplayer("<p,quiz>How are we going to make it look like a human?");
    ~chatnpc("<p,neutral>We'll just make a scarecrow. We'll need logs, and 10 sheaves of wheat for stuffing.");
    ~chatplayer("<p,quiz>How are we going to make it sound like a human?");
    ~chatnpc("<p,happy>That's what the parrot's for, of course.");
    ~chatnpc_specific("Parrot", eadgar_parrotts, "<p,neutral>Who's a pretty boy then?"); // mesanim lore_bird_chathead_quizical
    ~chatnpc("<p,neutral>Although the trolls might get suspicious if it doesn't say what they expect a human to say...");
    ~chatnpc("<p,neutral>You should hide it for a while somewhere it can pick up some more appropriate catchphrases.");
    ~chatplayer("<p,quiz>How are we going to make it smell like a human?");
    ~chatnpc("<p,neutral>Well, we'll need to dress it up anyway; if we use dirty clothes it'll smell human to the trolls.");
    ~chatnpc("<p,neutral>I'm a man of few clothes myself, so you might want to ask old Sanfew about that one.");
    ~chatplayer("<p,quiz>And how are we going to make it taste like a human?");
    ~chatnpc("<p,happy>That's easy, we'll just stuff it with a few chickens. Everything tastes like chicken! Five raw chickens should be enough!");
    %eadgar_quest = ^eadgar_explained_plan;
    ~chatnpc("<p,neutral>That's the plan. Anything else I can do for you?");
    @eadgar_default_tree;
} else {
    // rsprox/branon
    ~chatplayer("<p,neutral>I haven't been able to find one yet.");
    ~chatnpc("<p,neutral>Well, go see if the zoo have one."); // "have" instead of "has" is authentic, still present in OSRS
    @multi2("Where's the zoo?", eadgar_where_zoo, "Okay, I'll be right back.", eadgar_brb); 
}

[label,eadgar_where_zoo]
// rsprox/branon
~chatplayer("<p,quiz>Where's the zoo?");
~chatnpc("<p,neutral>It's in Ardougne, south west of here.");
@eadgar_brb;

[label,eadgar_brb]
// rsprox/branon
~chatplayer("<p,neutral>Okay, I'll be right back.");
@eadgar_anything_else_default_tree;

// if we've shown the parrot to eadgar but haven't hidden it yet, this dialog blocks turning in the other scarecrow supplies
[label,eadgar_hasnt_hidden_parrot]
if(inv_total(inv, eadgar_drunk_parrot) > 0 | inv_total(bank, eadgar_drunk_parrot) > 0) { // from indio's run, eadgar won't give another parrot if it's banked or in inventory
    @eadgar_what_do_with_parrot;
} else { // player has lost the parrot after showing it to eadgar
    @eadgar_lost_parrot;
}

[label,eadgar_what_do_with_parrot]
// rsprox/branon
~chatplayer("<p,quiz>What should I do with this parrot?");
~chatnpc("<p,neutral>I told you, put it somewhere it'll learn to say the sort of thing the trolls will expect it to say.");
~chatnpc("<p,neutral>This is likely to be screaming. There's bound to be a good spot somewhere in the troll prison.");
@eadgar_scarecrow_tree; // only time this dialog tree is accessible!

[proc,eadgar_lost_parrot_start] // this dialog is used in two places and needs to resume execution in both, so i made it a proc
// rsprox/branon
~chatnpc("<p,quiz>Oh, it's you. You didn't lose your parrot did you? One flew over here and I managed to capture it.");
~chatplayer("<p,idle>..."); // chatidleneu1

[label,eadgar_lost_parrot]
~eadgar_lost_parrot_start;
if(inv_freespace(inv) > 0) {
    inv_add(inv, eadgar_drunk_parrot, 1);
    // rsprox/branon
    ~chatnpc("<p,quiz>That's what I thought. Have it back.");
} else {
    // rsprox/indio
    ~chatnpc("<p,quiz>That's what I thought. Clear some space and take it back.");
}
@eadgar_what_do_with_parrot; // this always fires regardless of if the player has space (and actually gets the parrot back) or not

[label,eadgar_how_are_you_getting_on]
// rsprox/branon
~chatnpc("<p,neutral>How are you getting on?");
@eadgar_scarecrow_items;

[oploc1,eadgar_rack]
// rsprox/branon
if(%eadgar_quest >= ^eadgar_hid_parrot & %eadgar_quest <= ^eadgar_needs_potion) {
    switch_int(randominc(2)) {
        case 0 : ~chatnpc_specific("Parrot", eadgar_parrotts, "<p,neutral>Polly wanna cracker!");
        case 1 : ~chatnpc_specific("Parrot", eadgar_parrotts, "<p,neutral>Pieces of eight! Pieces of eight!");
        case 2 : ~chatnpc_specific("Parrot", eadgar_parrotts, "<p,neutral>Who's a pretty boy then?");
    }
    ~chatplayer("<p,neutral>I don't think it's done yet.");
} else if(%eadgar_quest = ^eadgar_needs_parrot_back) {
    ~mesbox("You look under the rack and find the drunk parrot.");
    ~chatnpc_specific("Parrot", eadgar_parrotts, "<p,neutral>Ah, hello Sir. Could you please free me?|I seem to have ... OW! What are you doing?|That's my spleen!"); // linebreaks from runeweb 2004
    ~chatplayer("<p,happy>I think it's probably heard enough.");
    inv_add(inv, eadgar_drunk_parrot, 1);
    %eadgar_quest = ^eadgar_got_parrot_back;
} else {
    ~mesbox("You look under the rack but find nothing.");
}

[oplocu,eadgar_rack]
switch_obj(last_useitem) {
    case eadgar_drunk_parrot : @eadgar_hide_parrot;
    case default : ~displaymessage(^dm_default);
}

[label,eadgar_hide_parrot]
if(%eadgar_quest = ^eadgar_explained_plan) {
    %eadgar_quest = ^eadgar_hid_parrot;
    mes("You hide the parrot under the torture rack.");
    inv_del(inv, eadgar_drunk_parrot, 1);
} else {
    mes("Why would you want to do that?");
}

[label,eadgar_hid_parrot]
// rsprox/branon
~chatplayer("<p,happy>I hid the parrot under the rack in the troll prison.");
~chatnpc("<p,happy>Good work. How about those other items?");
%eadgar_quest = ^eadgar_needs_items;
@eadgar_scarecrow_items;

[label,eadgar_scarecrow_tree]
// rsprox/branon
~chatnpc("<p,quiz>Anything else I can do for you?");
@multi5("How are we going to make it look like a human?", eadgar_scarecrow_look, "How are we going to make it sound like a human?", eadgar_scarecrow_sound,
        "How are we going to make it smell like a human?", eadgar_scarecrow_smell, "How are we going to make it taste like a human?", eadgar_scarecrow_taste,
        "More", eadgar_default_tree);

[label,eadgar_scarecrow_look]
// rsprox/branon
~chatplayer("<p,quiz>How are we going to make it look like a human?");
~chatnpc("<p,neutral>We'll just make a scarecrow. We'll need logs, and 10 sheaves of wheat for stuffing.");
@eadgar_scarecrow_tree;

[label,eadgar_scarecrow_sound]
// rsprox/branon
~chatplayer("<p,quiz>How are we going to make it sound like a human?");
~chatnpc("<p,happy>That's what the parrot's for, of course.");
~chatnpc("<p,neutral>You should hide it for a while somewhere it can pick up some more appropriate catchphrases.");
@eadgar_scarecrow_tree;

[label,eadgar_scarecrow_smell]
// rsprox/branon
~chatplayer("<p,quiz>How are we going to make it smell like a human?");
~chatnpc("<p,neutral>Well, we'll need to dress it up anyway; if we use dirty clothes it'll smell human to the trolls.");
~chatnpc("<p,neutral>I'm a man of few clothes myself, so you might want to ask old Sanfew about that one.");
@eadgar_scarecrow_tree;

[label,eadgar_scarecrow_taste]
// rsprox/branon
~chatplayer("<p,quiz>How are we going to make it smell like a human?");
~chatnpc("<p,happy>That's easy, we'll just stuff it with a few chickens. Everything tastes like chicken! Five raw chickens should be enough.");
@eadgar_scarecrow_tree;

[label,eadgar_scarecrow_items]
// All the videos and guides use normal logs but we checked some others:
// OSRS - Maple logs work but Redwood logs do not - likely not using a category.
// RS3 - Achey logs work.
//
// Current theory is that any 2004-era log should work, with priority from lowest to highest level.
// TODO not sure about pyre logs...
def_obj $log_type = null;
if(inv_total(inv, logs) > 0) {
    $log_type = logs;
} else if(inv_total(inv, achey_tree_logs) > 0) {
    $log_type = achey_tree_logs;
} else if(inv_total(inv, oak_logs) > 0) {
    $log_type = oak_logs;
} else if(inv_total(inv, willow_logs) > 0) {
    $log_type = willow_logs;
} else if(inv_total(inv, maple_logs) > 0) {
    $log_type = maple_logs;
} else if(inv_total(inv, yew_logs) > 0) {
    $log_type = yew_logs;
} else if(inv_total(inv, magic_logs) > 0) {
    $log_type = magic_logs;
}

def_int $logs_num = 0;
if($log_type ! null) {
    $logs_num = inv_total(inv, $log_type);
}
def_int $chickens_num = min(inv_total(inv, raw_chicken), calc(5 - %eadgar_chickens));
def_int $grain_num = min(inv_total(inv, grain), calc(10 - %eadgar_grain));
def_int $clothes_num = inv_total(inv, eadgar_dirty_druid_robe);
def_string $logs_str = "";
def_string $chickens_str = "";
def_string $grain_str = "";
def_string $clothes_str = "";

switch_int ($logs_num) {
    case 0 : $logs_str = "no logs";
    case default : $logs_str = "the logs";
}
switch_int ($chickens_num) {
    case 0 : $chickens_str = "no chickens";
    case 1 : $chickens_str = "one chicken";
    case default : $chickens_str = "<tostring($chickens_num)> chickens";
}
switch_int ($grain_num) {
    case 0 : $grain_str = "no grain";
    case 1 : $grain_str = "one bundle of grain";
    case default : $grain_str = "<tostring($grain_num)> bundles of grain";
}
switch_int ($clothes_num) {
    case 0 : $clothes_str = "no dirty clothes";
    case default : $clothes_str = "the dirty clothes";
}

// done building strings, now clamp values so we don't eat the player's items
$chickens_num = min(calc(5 - %eadgar_chickens), $chickens_num);
$grain_num = min(calc(10 - %eadgar_grain), $grain_num);

// videos show items are removed here, immediately before the player's "I have XYZ" dialog fires
if ($logs_num >= 1 & testbit(%eadgar_bits, ^eadgar_given_logs) = ^false) {
    inv_del(inv, $log_type, 1);
    %eadgar_bits = setbit(%eadgar_bits, ^eadgar_given_logs);
} else {
    $logs_str = "no logs";
    // Resetting the strings to say "no" even if the items are present in the inventory is done on purpose to match OSRS/RS3.
    // This happens for all the items, logs/chickens/grain/clothes. Works like this:
    //
    // Player gives Eadgar ALL of a required item (1 logs for example)
    // Player returns later with other items, while still carrying an extra of the previous item (1 extra logs to make a fire)
    // The player's dialog will read "I have no logs" while turning in other items, even though there are actually logs in the inventory.
}

if ($chickens_num > 0) {
    inv_del(inv, raw_chicken, $chickens_num);
} else {
    $chickens_str = "no chickens";
}

if ($grain_num > 0) {
    inv_del(inv, grain, $grain_num);
} else {
    $grain_str = "no grain";
}

if ($clothes_num >= 1 & testbit(%eadgar_bits, ^eadgar_given_clothes) = ^false) {
    inv_del(inv, eadgar_dirty_druid_robe, 1); // only one is taken when turning in
    %eadgar_bits = setbit(%eadgar_bits, ^eadgar_given_clothes);
} else {
    $clothes_str = "no dirty clothes"; // when turning in other items with drop-tricked clothes in the inventory, the player's dialog says "no dirty clothes"
}

// increment what we've brought
%eadgar_chickens = calc(%eadgar_chickens + $chickens_num);
%eadgar_grain = calc(%eadgar_grain + $grain_num);

// check if anything more is needed
def_int $chickens_needed = calc(5 - %eadgar_chickens);
def_int $grain_needed = calc(10 - %eadgar_grain);

// TODO we are currently missing a possible dialog line here:
//~chatplayer("<p,neutral>I don't have anything.");
//
// I ran across this in RS3 by talking to Eadgar with an empty inventory (no required items present)
// Appears to exist in OSRS too: https://chisel.weirdgloop.org/dialogue/content/2449
//
// The issue is I don't know if this line ONLY appears if the player has NO required item types at all,
// or if it also appears when (for example) all 10 grain have been turned in, but the player has 1 grain in their inventory
// and nothing else (required item is present, but it's not a type of item we still *need*)
~chatplayer("<p,neutral>I have <$logs_str>, <$chickens_str>, <$grain_str> and <$clothes_str>.");

// if not all items are delivered, dialog goes back to default tree after eadgar tells you what else is needed
// is clicking on eadgar after showing him the parrot but before hiding it the only way to see the scarecrow dialog tree?
if(testbit(%eadgar_bits, ^eadgar_given_logs) ! 1 | $chickens_needed > 0 | $grain_needed > 0 | testbit(%eadgar_bits, ^eadgar_given_clothes) ! 1) {
    // todo probably a better way to do this w/o code duplication
    switch_int (testbit(%eadgar_bits, ^eadgar_given_logs)) {
    case 1 : $logs_str = "no logs";
    case 0 : $logs_str = "the logs";
    }
    switch_int ($chickens_needed) {
        case 0 : $chickens_str = "no chickens";
        case 1 : $chickens_str = "one chicken";
        case default : $chickens_str = "<tostring($chickens_needed)> chickens";
    }
    switch_int ($grain_needed) {
        case 0 : $grain_str = "no grain";
        case 1 : $grain_str = "one bundle of grain";
        case default : $grain_str = "<tostring($grain_needed)> bundles of grain";
    }
    switch_int (testbit(%eadgar_bits, ^eadgar_given_clothes)) {
        case 1 : $clothes_str = "no dirty clothes";
        case 0 : $clothes_str = "the dirty clothes";
    }
    // rsprox/branon
    ~chatnpc("<p,neutral>You now need <$logs_str>, <$chickens_str>, <$grain_str> and <$clothes_str>.");
    @eadgar_anything_else_default_tree;
} else {
    @eadgar_thats_everything;
}

[debugproc,eadgar_resetitems]
if(p_finduid(uid) = true) {
    %eadgar_bits = clearbit(%eadgar_bits, ^eadgar_given_logs);
    %eadgar_bits = clearbit(%eadgar_bits, ^eadgar_given_clothes);
    %eadgar_chickens = 0;
    %eadgar_grain = 0;
}

[label,eadgar_thats_everything]
// rsprox/branon
~chatnpc("<p,neutral>That's everything!");
~chatnpc("<p,happy>Good, good, everything is almost finished.");
~chatnpc("<p,neutral>Of course, we can't just give him the dummy and expect to get anything useful out of him.");
~chatplayer("<p,neutral>Oh?");
~chatnpc("<p,neutral>No, of course not. We need to make sure he'll tell you what you need to know.");
~chatplayer("<p,quiz>And how do we do that?");
~chatnpc("<p,neutral>I happen to know that the trolls are susceptible to a|certain kind of plant that grows around this mountain.|I call it Troll Thistle. If properly prepared, it can|be made into a sort of Troll truth potion."); // linebreaks from runeweb 2004
@eadgar_how_prepare_troll_truth_potion;

[label,eadgar_how_prepare_troll_truth_potion]
// rsprox/branon
~chatplayer("<p,quiz>How do you prepare it?");
~chatnpc("<p,neutral>You'll have to dry it in a fire, then grind it and mix it into a potion with Ranarr weed.");
%eadgar_quest = ^eadgar_needs_potion;
~chatplayer("<p,neutral>Okay, I'll be back with that soon.");
@eadgar_anything_else_default_tree;

[label,eadgar_got_troll_truth_potion]
// rsprox/branon
if(inv_total(inv, eadgar_ground_troll_thistle_potion) > 0) {
    ~chatplayer("<p,happy>I've got the troll truth potion.");
    queue(eadgar_give_potion, 0, 0); // todo might actually be queued before player dialog above
    // Jagex appears to have changed this line at some point after 2014: https://youtu.be/945tUgBj3SM?t=860 
    // Eadgar says "thank you" instead of "hand it here" in OSRS now   
    ~chatnpc("<p,happy>Excellent, hand it here. Now just go fetch that poor parrot back, it's probably had enough by now."); 
} else {
    // rsprox/branon
    ~chatplayer("<p,quiz>How do I make the troll truth potion again?");
    ~chatnpc("<p,neutral>Troll Thistle grows around this mountain. If properly prepared, it can be made into a sort of Troll truth potion.");
    @eadgar_how_prepare_troll_truth_potion;
}

[queue,eadgar_give_potion]
%eadgar_quest = ^eadgar_needs_parrot_back;
inv_del(inv, eadgar_ground_troll_thistle_potion, 1); // only one is taken

[label,eadgar_needs_parrot_back]
// rsprox/branon
~chatnpc("<p,quiz>Did you get that parrot back?");
~chatplayer("<p,neutral>Not yet.");
~chatnpc("<p,neutral>Hurry up then.");

[label,eadgar_got_parrot_back]
if(inv_total(inv, eadgar_drunk_parrot) > 0) {
    // mesanims from RS3
    ~chatplayer("<p,happy>I've brought the parrot.");
    ~chatnpc("<p,happy>Hand it here...there we go! Can you tell this isn't a bona fide human being? I sure can't!");
} else {
    // rsprox/branon
    ~eadgar_lost_parrot_start;
    ~chatnpc("<p,quiz>That's what I thought.");
    ~chatnpc("<p,happy>Just give me a moment...there we go! Can you tell this isn't a bona fide human being? I sure can't!");
}
@eadgar_give_fake_man;

[label,eadgar_give_fake_man]
// to match OSRS videos - the drunk parrot/fake man swap is queued
// and does not occur until the player clicks through or cancels eadgar's default dialog tree
queue(eadgar_fake_man, 0, 0);
~chatnpc_specific("Fake man", eadgar_parrotts, "<p,neutral>What am I doing here? Ow! Where's the rest of the|Guard? Agh! I won't tell you anything!"); // linebreaks from runeweb 2004
@eadgar_default_tree;

[queue,eadgar_fake_man]
%eadgar_quest = ^eadgar_got_fake_man;
inv_add(inv, eadgar_fake_man, 1);
inv_del(inv, eadgar_drunk_parrot, 1);

[label,eadgar_given_fake_man_yet]
// rsprox/branon
~chatnpc("<p,quiz>Have you given the fake man to the troll cook yet?");
if(inv_total(inv, eadgar_fake_man) > 0) { // bank is not checked here
    ~chatplayer("<p,neutral>Not yet.");
    ~chatnpc("<p,neutral>Go on then, give it to the cook!");
} else {
    ~chatplayer("<p,sad>No. I lost it.");
    ~chatnpc("<p,angry>You bumbling imbecile!");
    inv_add(inv, eadgar_fake_man, 1); // this appears to be added in dialog (not queued) and drops to the ground here if inv is full
    ~chatnpc("<p,angry>Never mind, here's one I prepared earlier.");
}
@eadgar_anything_else_default_tree;

[label,eadgar_did_the_plan_work]
// rsprox/branon
~chatnpc("<p,quiz>Well? Did the plan work?");
~chatplayer("<p,happy>Yes! I can get into the storeroom now.");
~chatnpc("<p,happy>Glad to hear it!");
@eadgar_anything_else_default_tree;

[oploc1,eadgar_kitchen_drawers]
p_arrivedelay;
anim(human_openchest, 0);
sound_synth(cupboard_open, 1, 0);
p_delay(0);
loc_change(eadgar_kitchen_drawers_open, 300);

[oploc1,eadgar_kitchen_drawers_open]
p_arrivedelay;
anim(human_closechest, 0);
sound_synth(cupboard_close, 1, 0);
p_delay(0);
loc_change(eadgar_kitchen_drawers, 300);

[oploc2,eadgar_kitchen_drawers_open]
p_arrivedelay;
mes("You search the drawers...");
p_delay(0);
if(%eadgar_quest = ^eadgar_got_burnt_meat & inv_total(inv, eadgar_troll_storeroom_key) = 0 & inv_total(bank, eadgar_troll_storeroom_key) = 0) {
    if(inv_freespace(inv) > 0) {
        mes("You open the fake bottom of the drawer and find the storeroom key.");
        inv_add(inv, eadgar_troll_storeroom_key, 1);
    } else {
        mes("You open the fake bottom of the drawer and see a key, but don't have space to take it.");
    }
} else {
    mes("You don't find anything.");
}

[oploc1,eadgar_storeroomdoor]
if(coord = 0_44_157_53_37) {
    @eadgar_storeroom_open;
} else {
    if(%eadgar_quest >= ^eadgar_unlocked_storeroom) {
        @eadgar_storeroom_open;
    } else if(inv_total(inv, eadgar_troll_storeroom_key) > 0 & %eadgar_quest = ^eadgar_got_burnt_meat) { // todo any sound for unlocking?
        %eadgar_quest = ^eadgar_unlocked_storeroom;
        mes("You unlock the door.");
        inv_del(inv, eadgar_troll_storeroom_key, 1); // only one key is taken
        @eadgar_storeroom_open;
    } else {
        mes("You need to find the right key to open this door.");
    }
}

[label,eadgar_storeroom_open]
~open_and_close_door2(eadgar_storeroomdoor_open, ~check_axis(coord, loc_coord, loc_angle), door_open);

// big greetz to Ashie for this code
// https://www.youtube.com/watch?v=kovUX7iTHIw and https://www.youtube.com/watch?v=Kt5WcY9qP0g
// based off these the knockout from the patrolling guards and the goutweed guard are 1t slower
[ai_timer,_troll_sguard]
if(npc_coord ! npc_destination) %npc_int = ~coord_direction(npc_coord, npc_destination);

huntall(npc_coord, 0, 0);
while (huntnext = true) {
    ~troll_guard_attack;
}

huntall(~movecoord_indirection(npc_coord, %npc_int, 1), 0, 0);
while (huntnext = true) {
    ~troll_guard_attack;
}

if(npc_coord = npc_destination) return;

huntall(~movecoord_indirection(npc_coord, %npc_int, 2), 0, 0);
while (huntnext = true) {
    ~troll_guard_attack;
}

[proc,troll_guard_attack]
if (getqueue(eadgar_take_goutweed) > 0 | getqueue(troll_guard_knockout) > 0 | getqueue(troll_guard_teleport) > 0) {
    return;
}
if_close;
npc_say("!");
npc_anim(eadgar_troll_axethrow, 0);
~player_projectile(npc_coord, coord, uid, spotanim_290, 40, 36, 41, 15, 5, 11, 5);
sound_synth(throw_club, 1, 0);
queue(troll_guard_knockout, 2, 0);

[ai_timer,eadgar_storeroom_guard]
~sound_area(troll_snore, 0, npc_coord, 5);
spotanim_npc(troll_zeds, 0, 0);
npc_facesquare(movecoord(npc_coord, 0, 0, 1));
npc_settimer(~random_range(8, 16));

[oploc1,eadgar_crate_goutweed] // todo what happens if you hold the objbox open and get hit by a patrolling guard?
// guess based on osrs videos, it's pretty centered vertically but looks scaled down slightly
// todo change to match https://web.archive.org/web/20051025140652im_/http://www.runeweb.net/fireball/Eadgars%20Ruse%20Images/Eadgar18.PNG
if (getqueue(eadgar_take_goutweed) > 0 | getqueue(troll_guard_knockout) > 0 | getqueue(troll_guard_teleport) > 0) {
    return;
}
queue(eadgar_take_goutweed, 0, 0);
inv_add(inv, eadgar_goutweed_herb, 1);
~objbox(eadgar_goutweed_herb, "You've found some goutweed!", 225, 0, calc(^objbox_height / 4));

[queue,eadgar_take_goutweed]
if(inzone(0_44_157_0_0, 0_44_157_63_63, coord) = false) {
    return;
}
if(npc_findexact(0_44_157_41_27, eadgar_storeroom_guard) = true) {
    npc_say("Hm?");
    npc_facesquare(coord);
    npc_anim(eadgar_troll_axethrow, 0);
    ~player_projectile(npc_coord, coord, uid, spotanim_290, 40, 36, 41, 15, 5, 11, 5);
    sound_synth(throw_club, 1, 0);
    queue(troll_guard_knockout, 2, 0);
}

[queue,troll_guard_knockout]
if(inzone(0_44_157_0_0, 0_44_157_63_63, coord) = false) {
    return;
}
if_openoverlay(eadgar_fade_to_black);
sound_synth(rock_impact, 1, 0);
anim(eadgar_knockout, 0);
~damage_self(random(7)); // osrs wiki says 0-6 damage is possible
queue(troll_guard_teleport, 1, 0);
queue(clear_overlay, 2, 0);

[queue,troll_guard_teleport]
// https://youtu.be/Kt5WcY9qP0g?si=D79k9J7lXVZxVOa-&t=944, fades out rather than
// clearing instantly, although this is a different interface, doesn't seem to work correctly with the 
// timing + this interface, so likely that just didn't happen until the interface was updated
if(inzone(0_44_157_0_0, 0_44_157_63_63, coord) = false) {
    return;
}
p_teleport(0_44_157_49_40);
spotanim_pl(spotanim_291, 124, 0);
sound_synth(stun_all, 1, 0);

[queue,eadgar_quest_complete]
session_log(^log_adventure, "Quest complete: Eadgar's Ruse");
%eadgar_quest = ^eadgar_complete;
stat_advance(herblore, 110000);
// https://web.archive.org/web/20051025140652im_/http://www.runeweb.net/fireball/Eadgars%20Ruse%20Images/Eadgar19.PNG
// no apostrophe
~send_quest_complete(questlist:eadgar, eadgar_goutweed_herb, 250, ^eadgar_questpoints, "You have completed\\nEadgars Ruse!");
