[opnpc1,viking_man]
if(%viking = ^viking_not_started | %viking = ^viking_complete) {
    @viking_citizen_default;
} else if (%viking < ^viking_complete) {
    ~chatplayer("<p,quiz>Hello. Are you a council member?");
    ~chatnpc("<p,neutral>Could be. Who wants to know?");
    ~chatplayer("<p,confused>Er... I do.");
    ~chatnpc("<p,neutral>Well, yes I am. Why do you want to find a council member?");
    ~chatplayer("<p,happy>I would like to become a Fremennik!");
    ~chatnpc("<p,neutral>Ah, I see. And you require a majority vote at the council of elders before you will be accepted into the clan, correct?");
    ~chatplayer("<p,happy>That's right! So can I have your vote?");
    ~chatnpc("<p,neutral>I don't like outerlanders. The only way you will get my vote allowing you into the clan is...");
    ~chatplayer("<p,quiz>Yes?");
    ~chatnpc("<p,neutral>If you can pay me... One hundred thousand, million, billion, nine hundred thousand, and forty seven hundred and ninety three gold coins.");
    ~chatplayer("<p,shock>WHAT?!?!?! I don't have 100,000,000,000,000,000,900,470,093 coins!!!! NOBODY has that many coins!!!");
    ~chatnpc("<p,neutral>I guess you don't get my vote then, do you, outerlander?");
}

[opnpc1,viking_man2]
if(%viking = ^viking_not_started | %viking = ^viking_complete) {
    @viking_citizen_default;
} else if (%viking < ^viking_complete) {
    ~chatplayer("<p,quiz>Hello, are you a member of the council?");
    ~chatnpc("<p,neutral>I am afraid not outerlander. Goodbye.");
}

[opnpc1,viking_man3]
if(%viking = ^viking_not_started | %viking = ^viking_complete) {
    @viking_citizen_default;
} else if(%viking = ^viking_complete) {
    ~chatplayer("<p,neutral>Hello.");
    ~chatnpc("<p,happy><~get_viking_name>... It has been too long since last we met!");
}

