[opnpc2,horror_dagannoth_jr4]
if (%npc_aggressive_player ! uid) {
    mes("It's not after you...");
    return;
}
@player_combat_start;

[apnpc2,horror_dagannoth_jr4]
if (%npc_aggressive_player ! uid) {
    mes("It's not after you...");
    return;
}
@player_combat_start_ap;

[ai_queue3,horror_dagannoth_jr4]
gosub(npc_death);
if (npc_findhero = ^false) {
    return;
}
if (%npc_aggressive_player = uid) {
    if(%horrorquest = ^horror_repaired_lighthouse) {
        queue(queue_defeat_dagjr, 0, 0);
    }
}

[queue,queue_defeat_dagjr]
%horrorquest = ^horror_defeated_dagjr;
~chatplayer("<p,happy>Okay, now that the creature's dead we can get you out of here.");
if(inzone(0_39_72_0_0, 0_39_72_63_63, coord) = true) queue(spawn_dagmother, 0, 0);
if(npc_findexact(0_39_72_22_25, horror_lighthousekeeeper_injured) = ^true) {
    ~chatnpcnoturn("<p,scared>No... you do not understand...");
    ~chatnpcnoturn("<p,scared>That was not the creature that attacked me...");
    ~chatnpcnoturn("<p,scared>That was one of its babies...");
}

// works similar to sara wizards, check prayer so we dont get
// stuck in setmode loop if spam clicking
[opnpc2,_dagannoth_mother]
if (%npc_aggressive_player ! uid) {
    mes("It's not after you...");
    return;
}
if (~check_protect_prayer(^melee_style) = false) {
    npc_setmode(opplayer2);
}
@player_combat_start;

[apnpc2,_dagannoth_mother] 
if (%npc_aggressive_player ! uid) {
    mes("It's not after you...");
    return;
}
if (~check_protect_prayer(^ranged_style) = false) {
    npc_setmode(applayer2);
}
@player_combat_start_ap;

[ai_queue1,_dagannoth_mother]
if(npc_getmode = applayer2) ~npc_default_retaliate_ap;
else ~npc_default_retaliate;

// only melees in op, only ranges in ap, will switch to ranged if you're praying melee and vice versa
// if you switch prayer every tick she will never attack (matches osrs) :)
[ai_opplayer2,_dagannoth_mother]
if (~check_protect_prayer(^melee_style) = true) {
    npc_setmode(applayer2);
    return;
}
gosub(npc_default_attack);

[ai_applayer2,_dagannoth_mother]
if (~check_protect_prayer(^ranged_style) = true) {
    npc_setmode(opplayer2);
    return;
}
~dagannoth_rangeattack(12, ^true);

[proc,dagannoth_rangeattack](int $maxhit, int $double_roll)
if (%npc_action_delay > map_clock) {
    npc_setmode(applayer2);
    return;
}
if (~npc_check_notcombat = false) {
    npc_setmode(null);
    return;
}
if (~npc_check_notcombat_self = false) {
    return;
}

def_int $attack_roll = ~npc_ranged_attack_roll;
def_int $defence_roll = ~player_defence_roll_specific(^ranged_style); // TODO: confirm if this rolls against ranged def (prob does...)

npc_anim(horror_dagannoth_rangeattack, 0);
~.sound_area(dagganoth_spines, 0, npc_coord, 10);

%npc_action_delay = add(map_clock, npc_param(attackrate));
// map_projanim_v2	id=horror_spines_travel (294), starttime=10, endtime=66, angle=25, progress=50, startheight=210, endheight=110
def_int $duration = ~player_projectile(npc_coord, coord, uid, spotanim_294, 52, 28, 10, 25, 36, 50, 5);
def_int $damage = randominc($maxhit);
def_int $damage2 = randominc($maxhit);
if_close; // close the player interface when taking a hit.
if (~check_protect_prayer(^ranged_style) = true) { 
    $damage = 0;
    $damage2 = 0;
}
anim(%com_defendanim, $duration);
queue(combat_damage_player, calc($duration / 30), $damage);
if($double_roll = ^true) queue(combat_damage_player, calc($duration / 30), $damage2);
queue*(playerhit_n_retaliate, calc($duration / 30))(npc_uid);
~npc_set_attack_vars;

[ai_timer,horror_dagganoth_air]
if(finduid(%npc_aggressive_player) = true) {
    if(distance(coord, npc_coord) > 17) {
        npc_del;
        return;
    }
    npc_changetype(horror_dagganoth_water, 1000);
    %aggressive_npc = npc_uid;
    npc_say("Krrrrrrk");
    //mes("The Dagannoth changes to blue..."); https://oldschool.runescape.wiki/w/Update:More_Small_Changes, TODO: enable for 289
    // can switch mode between phase changes
    if(random(2) = 0) npc_setmode(opplayer2);
    else npc_setmode(applayer2);
    ~.sound_area(dagganoth_changes, 0, npc_coord, 10);
    return;
}
npc_del;

