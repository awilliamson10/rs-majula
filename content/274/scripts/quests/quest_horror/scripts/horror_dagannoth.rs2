[ai_queue3,_dagannoth_mother]
gosub(npc_death);
// requires kill credit supposedly
if (npc_findhero = ^false) {
    return;
}
if (%npc_aggressive_player = uid) { // should always be true but just incase
    if(%horrorquest = ^horror_defeated_dagjr) {
        queue(quest_horror_complete, 0, 0);
    }
}

[queue,spawn_dagmother]
npc_huntall(0_39_72_24_36, 25, 0);
while (npc_findnext = true) {
    if(%npc_aggressive_player = uid) {
        npc_setmode(opplayer2);
        return;
    }
}
cam_moveto(0_39_72_18_37, 500, 50, 10);
p_delay(0);
def_coord $start = 0_39_72_10_34;
npc_add($start, horror_dagganoth_aira, 1000);
~.sound_area(dagganoth_chitters, 0, npc_coord, 10);
%npc_aggressive_player = uid;
%aggressive_npc = npc_uid;
hint_stop;
hint_npc;
cam_lookat(0_39_72_13_36, 100, 50, 10);
p_delay(1);
npc_changetype(horror_dagganoth_airb, 1000);
npc_walk(movecoord($start, 1, 0, 0));
p_delay(1);
npc_changetype(horror_dagganoth_airc, 1000);
npc_walk(movecoord($start, 2, 0, 0));
p_delay(1);
npc_changetype(horror_dagganoth_air, 1000);
npc_tele(map_findsquare(0_39_72_24_38, 0, 8, ^map_findsquare_lineofwalk));
npc_setmode(applayer2);
cam_reset;

[ai_queue1,horror_dagganoth_jr] ~npc_default_retaliate_ap;
[ai_opplayer2,horror_dagganoth_jr] npc_setmode(applayer2);
[ai_applayer2,horror_dagganoth_jr] ~dagannoth_rangeattack(8, ^false);

[ai_queue1,horror_dagganoth_jr_lighter] ~npc_default_retaliate_ap;
[ai_opplayer2,horror_dagganoth_jr_lighter] npc_setmode(applayer2);
[ai_applayer2,horror_dagganoth_jr_lighter] ~dagannoth_rangeattack(8, ^false);

[ai_queue1,horror_dagganoth_jr_darker] ~npc_default_retaliate_ap;
[ai_opplayer2,horror_dagganoth_jr_darker] npc_setmode(applayer2);
[ai_applayer2,horror_dagganoth_jr_darker] ~dagannoth_rangeattack(8, ^false);


[ai_queue3,_dagganoth]
gosub(npc_death);
if (npc_findhero = ^false) {
    return;
}

obj_add(npc_coord, npc_param(death_drop), 1, ^lootdrop_duration);
~trail_mediumcluedrop(128, npc_coord);

def_int $random = random(128);

if($random < 6) obj_add(npc_coord, iron_spear, 1, ^lootdrop_duration);
else if($random < 11) obj_add(npc_coord, bronze_spear, 1, ^lootdrop_duration);
else if($random < 12) obj_add(npc_coord, mithril_spear, 1, ^lootdrop_duration);
else if($random < 16) obj_add(npc_coord, waterrune, 15, ^lootdrop_duration);
else if($random < 18) obj_add(npc_coord, steel_arrow, 15, ^lootdrop_duration);
else if($random < 19) obj_add(npc_coord, mithril_javelin, 3, ^lootdrop_duration);
else if($random < 31) obj_add(npc_coord, lobster_pot, 1, ^lootdrop_duration);
else if($random < 35) obj_add(npc_coord, raw_herring, 3, ^lootdrop_duration);
else if($random < 39) obj_add(npc_coord, raw_sardine, 5, ^lootdrop_duration);
else if($random < 42) obj_add(npc_coord, harpoon, 1, ^lootdrop_duration);
else if($random < 44) obj_add(npc_coord, feather, 15, ^lootdrop_duration);
else if($random < 46) obj_add(npc_coord, fishing_bait, 50, ^lootdrop_duration);
else if($random < 48) obj_add(npc_coord, raw_lobster, 1, ^lootdrop_duration);
else if($random < 50) obj_add(npc_coord, raw_tuna, 1, ^lootdrop_duration);
else if($random < 52) obj_add(npc_coord, seaweed, 10, ^lootdrop_duration);
else if($random < 53) obj_add(npc_coord, bigoysterpearls, 1, ^lootdrop_duration);
else if($random < 54) obj_add(npc_coord, smalloysterpearls, 1, ^lootdrop_duration);
else if($random < 83) obj_add(npc_coord, coins, 56, ^lootdrop_duration);
else if($random < 92) obj_add(npc_coord, coins, 25, ^lootdrop_duration);
else if($random < 100) obj_add(npc_coord, coins, 44, ^lootdrop_duration);
else if($random < 106) obj_add(npc_coord, coins, 41, ^lootdrop_duration);
else if($random < 108) obj_add(npc_coord, opal_bolttips, 12, ^lootdrop_duration);
else if($random < 109) obj_add(npc_coord, casket, 1, ^lootdrop_duration);
else if($random < 110) obj_add(npc_coord, ~randomjewel, ^lootdrop_duration);
