[ai_opplayer2,vampire_spider]
npc_setmode(applayer2);

[ai_applayer2,vampire_spider]
if(%npc_int = 0) {
    ~spawn_vampire;
}

[ai_timer,vampire_spider]
if(%npc_int > 0) {
    %npc_int = sub(%npc_int, 1);
}

[proc,spawn_vampire]
%npc_int = 100; // 60s between spawns
npc_add(map_findsquare(coord, 1, 3, ^map_findsquare_lineofsight), vampire_flyer, 1000); // distance of 3, 1000t osrs
npc_anim(vamp_land, 0);
npc_facesquare(coord);
%npc_aggressive_player = uid;
npc_setmode(opplayer2);
%npc_lastcombat = sub(^max_32bit_int, 8);
