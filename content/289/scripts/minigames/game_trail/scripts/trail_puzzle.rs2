[opheld1,_trail_puzzle] @trail_open_puzzle(last_item);

[label,trail_open_puzzle](obj $puzzle)
if(inv_freespace(trail_puzzleinv) > 1) {
    inv_clear(trail_puzzleinv); // prob shouldn't ever need this
    ~init_trail_puzzle($puzzle);
}
inv_transmit(trail_puzzleinv, trail_puzzle:com_2);
inv_transmit(trail_puzzlehintinv, trail_puzzle:com_8);
if_openmain(trail_puzzle);

