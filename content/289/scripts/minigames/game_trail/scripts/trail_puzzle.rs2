// This achieves randomization by essentially simulating 101 moves using the adj slot to each piece starting from the bottom right
// (since the puzzle is init'd in a completed state: https://x.com/JagexAsh/status/1301202083845201921)
[proc,shuffle_trail_puzzle]
def_int $moves = 101;
def_int $current_idx = 24;
while($moves > 0) {
    // horizontal
    def_int $next_idx = ~random_puzzle_slot($current_idx);
    if($next_idx ! -1) {
        inv_movetoslot(trail_puzzleinv, trail_puzzleinv, $next_idx, $current_idx);
    }
    $moves = calc($moves - 1);
    $current_idx = $next_idx;
}

[proc,random_puzzle_slot](int $slot)(int)
def_int $left_slot = -1;
def_int $right_slot = -1;
def_int $down_slot = -1;
def_int $up_slot = -1;
def_int $adj_slots = 0;
if (modulo($slot, 5) ! 0) {
    $left_slot = calc($slot - 1);
    $adj_slots = calc($adj_slots + 1);
}
if (modulo($slot, 5) ! 4) {
    $right_slot = calc($slot + 1);
    $adj_slots = calc($adj_slots + 1);
}

// vertical
if($slot >= 5) {
    $up_slot = calc($slot - 5);
    $adj_slots = calc($adj_slots + 1);
}
if($slot <= 19) {
    $down_slot = calc($slot + 5);
    $adj_slots = calc($adj_slots + 1);
} 

// Randomly select one of the available adjacent slots
if ($adj_slots > 0) {
    def_int $random_index = random($adj_slots);
    if ($left_slot ! -1) {
        if ($random_index = 0) {
            return ($left_slot);
        }
    } 

    if ($right_slot ! -1) {
        if ($random_index = 0 & $left_slot = -1) {
            return ($right_slot);
        } else if ($random_index = 1) {
            return ($right_slot);
        }
    } 

    if ($up_slot ! -1) {
        if ($random_index <= 1 & $right_slot = -1) {
            return ($up_slot);
        } else if ($random_index = 2) {
            return ($up_slot);
        }
    }

    if ($down_slot ! -1) {
        if ($random_index <= 2 & $up_slot = -1) {
            return ($down_slot);
        } else if ($random_index = 3) {
            return ($down_slot);
        }
    }
}
return ($down_slot);

[proc,trail_puzzle_complete](namedobj $puzzle)(boolean)
def_int $puztype = oc_param($puzzle, trail_puzzle);
if($puztype = ^trail_puzzleb) {
    if (inv_getobj(trail_puzzleinv, 0) = trail_slidingpuzzleb01 &
            inv_getobj(trail_puzzleinv, 1) = trail_slidingpuzzleb02 &
            inv_getobj(trail_puzzleinv, 2) = trail_slidingpuzzleb03 &
            inv_getobj(trail_puzzleinv, 3) = trail_slidingpuzzleb04 &
            inv_getobj(trail_puzzleinv, 4) = trail_slidingpuzzleb05 &
            inv_getobj(trail_puzzleinv, 5) = trail_slidingpuzzleb06 &
            inv_getobj(trail_puzzleinv, 6) = trail_slidingpuzzleb07 &
            inv_getobj(trail_puzzleinv, 7) = trail_slidingpuzzleb08 &
            inv_getobj(trail_puzzleinv, 8) = trail_slidingpuzzleb09 &
            inv_getobj(trail_puzzleinv, 9) = trail_slidingpuzzleb10 &
            inv_getobj(trail_puzzleinv, 10) = trail_slidingpuzzleb11 &
            inv_getobj(trail_puzzleinv, 11) = trail_slidingpuzzleb12 &
            inv_getobj(trail_puzzleinv, 12) = trail_slidingpuzzleb13 &
            inv_getobj(trail_puzzleinv, 13) = trail_slidingpuzzleb14 &
            inv_getobj(trail_puzzleinv, 14) = trail_slidingpuzzleb15 &
            inv_getobj(trail_puzzleinv, 15) = trail_slidingpuzzleb16 &
            inv_getobj(trail_puzzleinv, 16) = trail_slidingpuzzleb17 &
            inv_getobj(trail_puzzleinv, 17) = trail_slidingpuzzleb18 &
            inv_getobj(trail_puzzleinv, 18) = trail_slidingpuzzleb19 &
            inv_getobj(trail_puzzleinv, 19) = trail_slidingpuzzleb20 &
            inv_getobj(trail_puzzleinv, 20) = trail_slidingpuzzleb21 &
            inv_getobj(trail_puzzleinv, 21) = trail_slidingpuzzleb22 &
            inv_getobj(trail_puzzleinv, 22) = trail_slidingpuzzleb23 &
            inv_getobj(trail_puzzleinv, 23) = trail_slidingpuzzleb24) {
        return (true);
    }
} else if($puztype = ^trail_puzzlec) {
    if (inv_getobj(trail_puzzleinv, 0) = trail_slidingpuzzlec01 &
            inv_getobj(trail_puzzleinv, 1) = trail_slidingpuzzlec02 &
            inv_getobj(trail_puzzleinv, 2) = trail_slidingpuzzlec03 &
            inv_getobj(trail_puzzleinv, 3) = trail_slidingpuzzlec04 &
            inv_getobj(trail_puzzleinv, 4) = trail_slidingpuzzlec05 &
            inv_getobj(trail_puzzleinv, 5) = trail_slidingpuzzlec06 &
            inv_getobj(trail_puzzleinv, 6) = trail_slidingpuzzlec07 &
            inv_getobj(trail_puzzleinv, 7) = trail_slidingpuzzlec08 &
            inv_getobj(trail_puzzleinv, 8) = trail_slidingpuzzlec09 &
            inv_getobj(trail_puzzleinv, 9) = trail_slidingpuzzlec10 &
            inv_getobj(trail_puzzleinv, 10) = trail_slidingpuzzlec11 &
            inv_getobj(trail_puzzleinv, 11) = trail_slidingpuzzlec12 &
            inv_getobj(trail_puzzleinv, 12) = trail_slidingpuzzlec13 &
            inv_getobj(trail_puzzleinv, 13) = trail_slidingpuzzlec14 &
            inv_getobj(trail_puzzleinv, 14) = trail_slidingpuzzlec15 &
            inv_getobj(trail_puzzleinv, 15) = trail_slidingpuzzlec16 &
            inv_getobj(trail_puzzleinv, 16) = trail_slidingpuzzlec17 &
            inv_getobj(trail_puzzleinv, 17) = trail_slidingpuzzlec18 &
            inv_getobj(trail_puzzleinv, 18) = trail_slidingpuzzlec19 &
            inv_getobj(trail_puzzleinv, 19) = trail_slidingpuzzlec20 &
            inv_getobj(trail_puzzleinv, 20) = trail_slidingpuzzlec21 &
            inv_getobj(trail_puzzleinv, 21) = trail_slidingpuzzlec22 &
            inv_getobj(trail_puzzleinv, 22) = trail_slidingpuzzlec23 &
            inv_getobj(trail_puzzleinv, 23) = trail_slidingpuzzlec24) {
        return (true);
    }
} else if($puztype = ^trail_puzzled) {
    if (inv_getobj(trail_puzzleinv, 0) = trail_slidingpuzzled01 &
            inv_getobj(trail_puzzleinv, 1) = trail_slidingpuzzled02 &
            inv_getobj(trail_puzzleinv, 2) = trail_slidingpuzzled03 &
            inv_getobj(trail_puzzleinv, 3) = trail_slidingpuzzled04 &
            inv_getobj(trail_puzzleinv, 4) = trail_slidingpuzzled05 &
            inv_getobj(trail_puzzleinv, 5) = trail_slidingpuzzled06 &
            inv_getobj(trail_puzzleinv, 6) = trail_slidingpuzzled07 &
            inv_getobj(trail_puzzleinv, 7) = trail_slidingpuzzled08 &
            inv_getobj(trail_puzzleinv, 8) = trail_slidingpuzzled09 &
            inv_getobj(trail_puzzleinv, 9) = trail_slidingpuzzled10 &
            inv_getobj(trail_puzzleinv, 10) = trail_slidingpuzzled11 &
            inv_getobj(trail_puzzleinv, 11) = trail_slidingpuzzled12 &
            inv_getobj(trail_puzzleinv, 12) = trail_slidingpuzzled13 &
            inv_getobj(trail_puzzleinv, 13) = trail_slidingpuzzled14 &
            inv_getobj(trail_puzzleinv, 14) = trail_slidingpuzzled15 &
            inv_getobj(trail_puzzleinv, 15) = trail_slidingpuzzled16 &
            inv_getobj(trail_puzzleinv, 16) = trail_slidingpuzzled17 &
            inv_getobj(trail_puzzleinv, 17) = trail_slidingpuzzled18 &
            inv_getobj(trail_puzzleinv, 18) = trail_slidingpuzzled19 &
            inv_getobj(trail_puzzleinv, 19) = trail_slidingpuzzled20 &
            inv_getobj(trail_puzzleinv, 20) = trail_slidingpuzzled21 &
            inv_getobj(trail_puzzleinv, 21) = trail_slidingpuzzled22 &
            inv_getobj(trail_puzzleinv, 22) = trail_slidingpuzzled23 &
            inv_getobj(trail_puzzleinv, 23) = trail_slidingpuzzled24) {
        return (true);
    }
}
return (false);

[opheld5,_trail_puzzle_piece]
def_int $slot = last_slot;
def_int $open_slot = -1;
    
// horizontal
if (modulo($slot, 5) ! 0) {
    if (inv_getobj(trail_puzzleinv, calc($slot - 1)) = null) $open_slot = calc($slot - 1);
}
if (modulo($slot, 5) ! 4) {
    if (inv_getobj(trail_puzzleinv, calc($slot + 1)) = null) $open_slot = calc($slot + 1);
}

// vertical
if($slot >= 5) {
    if (inv_getobj(trail_puzzleinv, calc($slot - 5)) = null) $open_slot = calc($slot - 5);
}
if($slot <= 19) {
    if (inv_getobj(trail_puzzleinv, calc($slot + 5)) = null) $open_slot = calc($slot + 5);
} 

if($open_slot ! -1) {
    sound_synth(slide_puzzle, 1, 0);
    inv_movetoslot(trail_puzzleinv, trail_puzzleinv, $slot, $open_slot);
}
