[label,boardgames_howto]
~chatplayer("<p,quiz>How do I play board games?");
~chatnpc("<p,neutral>You can challenge someone to a game anywhere in the|Games Zone by using the right click option.");
~chatnpc("<p,neutral>Choose the type of game and then choose the options|you want such as time per move.");
~chatnpc("<p,neutral>If your opponent accepts the challenge you will be|taken to one of the tables around where you will play|your game of choice.");
~chatnpc("<p,neutral>Once you have finished your game you will come back|here where you can challenge again! We also have|tables in a few pubs around the world!");
@boardgames_questions;
