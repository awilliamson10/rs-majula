//Todo: Dialogue is all from osrs with runesquares and runeversi mentions removed

[apnpc1,boardgames_barmaid]
if (npc_range(coord) > 3) {
    p_aprange(3);
    return;
}
~chatnpc("<p,happy>Welcome to the Burthorpe Games Rooms!");
@boardgames_questions;

[apnpc3,boardgames_barmaid]
if (npc_range(coord) > 3) {
    p_aprange(3);
    return;
}
~openshop_activenpc;

[label,boardgames_questions]
@multi4("How do I play board games?", boardgames_howto, "What games can I play?", boardgames_which, "Can I buy a drink please?", boardgames_drink, "Thanks!", boardgames_thanks);

[label,boardgames_which]
~chatplayer("<p,quiz>What games can I play?");
~chatnpc("<p,neutral>Currently we offer Draughts and Runelink.");
@multi2("Draughts?", boardgames_draughts, "Runelink?", boardgames_runelink);

[label,boardgames_drink]
~chatplayer("<p,quiz>Can I buy a drink please?");
~chatnpc("<p,neutral>I'm afraid I don't sell drinks.");

[label,boardgames_thanks]
~chatplayer("<p,happy>Thanks!");

[label,boardgames_draughts]
~chatplayer("<p,confused>Draughts?");
~chatnpc("<p,happy>Draughts uses standard rules, apart from: a draw is|declared if no piece has been taken or promoted for|forty moves.");
@boardgames_questions;

[label,boardgames_runelink]
~chatplayer("<p,confused>Runelink?");
~chatnpc("<p,happy>Yup, you have to get four runes in a row.");
@boardgames_questions;

