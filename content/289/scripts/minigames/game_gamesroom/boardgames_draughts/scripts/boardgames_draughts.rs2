[if_button,boardgames_draughts_options:challenge]
%boardgames_closinginterface = 1;
if_close;
if (.finduid(%duel2accept) = false) {
    ~reset_boardgames_varp;
    %duel2accept = null;
    mes("That player is no longer available.");
    return;    
}
if (.busy = true) {
    ~reset_boardgames_varp;
    %duel2accept = null;
    mes("Other player is busy at the moment.");
    return;
}
if (~in_games_room(.coord) = false) {
    ~reset_boardgames_varp;
    %duel2accept = null;
    mes("Other player has left the area.");
    return;
}

if(.%duel2accept = uid) {
    if(inzone(1_34_77_16_8, 1_34_77_23_15, coord) = true) {
        %boardgames_challengeroom = 1;
        .%boardgames_challengeroom = 1;
    } else {
        %boardgames_challengeroom = 0;
        .%boardgames_challengeroom = 0;
    }

    ~boardgames_table_setup;
    
    if(%boardgames_tablenum = -1) {
        ~reset_boardgames_varp;
        %duel2accept = null;
        return;
    }

    if_openoverlay(null);
    set_skill_level(0);
    ~update_bas;
    .if_openoverlay(null);
    .set_skill_level(0);
    ~.update_bas;
    ~init_draughts_boardsetup;
    ~.init_draughts_boardsetup;
    ~first_draughts_turn;
} else {
    %boardgames_closinginterface = 0;
    mes("Sending challenge...");
    ~send_boardgames_challenge_request;
}

[if_button,boardgames_draughts:offer_draw]
if (.finduid(%duel2accept) = false) {
    return;
}

if (%boardgames_drawrequested = 1) {
    ~draughts_process_draw;
} else {
    // This uses other text com in old videos. Unknown if status1 can display at same time or if it resets each move https://youtu.be/S1VYbmOb_2w?si=hZnBkXdeH1L2fxIB&t=496
    if_settext(boardgames_draughts:status2, "Asking opponent for a draw...");
    .if_settext(boardgames_draughts:status2, "Your opponent asked for a draw.");
    .%boardgames_drawrequested = 1;
}

[proc,init_draughts_boardsetup]
%boardgames_ingame = 1;
%boardgames_closemode = ^boardgames_loss;
minimap_toggle(1);

%boardgames_closinginterface = 1;
if_setanim(boardgames_draughts:runeflash, null);
if_setanim(boardgames_draughts:runeflash, runeflash_off);
if_openmain(boardgames_draughts);
%boardgames_closinginterface = 0;

if_setobject(boardgames_draughts:p1_rune, ~get_boardgames_rune_obj(%boardgames_piece), 72);
if_setobject(boardgames_draughts:p2_rune, ~get_boardgames_rune_obj(.%boardgames_piece), 72);
if (%boardgames_rankedgame = 1) {
    if_settext(boardgames_draughts:p1_name, "<displayname> (<tostring(%boardgames_draughts_rank)>)");
    if_settext(boardgames_draughts:p2_name, "<.displayname> (<tostring(.%boardgames_draughts_rank)>)");
} else {
    if_settext(boardgames_draughts:p1_name, "<displayname>");
    if_settext(boardgames_draughts:p2_name, "<.displayname>");
}

inv_clear(boardgames_boardinv);
~boardgames_hide_tabs;

def_namedobj $p1_rune = ~get_boardgames_player_rune(.%boardgames_piece);
inv_setslot(boardgames_boardinv, 1, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 3, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 5, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 7, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 8, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 10, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 12, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 14, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 17, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 19, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 21, $p1_rune, 1);
inv_setslot(boardgames_boardinv, 23, $p1_rune, 1);

