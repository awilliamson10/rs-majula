inv_setslot(boardgames_boardinv, 40, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 42, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 44, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 46, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 49, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 51, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 53, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 55, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 56, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 58, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 60, $p2_rune, 1);
inv_setslot(boardgames_boardinv, 62, $p2_rune, 1);

inv_transmit(boardgames_boardinv, boardgames_draughts:boardinv);

