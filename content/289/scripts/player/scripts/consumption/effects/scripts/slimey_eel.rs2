[label,consume_effect_mort_slimey_eel_cooked]
// OSRS
// TODO: Change this to "slimy" Jul 5th 2005 (rev 320+)
mes("You eat the cooked slimey eel - ummm, slimey!");
sound_synth(eat, 1, 0);
anim(human_eat, 0);
inv_delslot(inv, last_slot);
def_int $hitpoints = stat(hitpoints);
def_int $heal = add(random(5),6);
if ($hitpoints < stat_base(hitpoints)) {
    stat_heal(hitpoints, $heal, 0);
    mes("It heals some health.");
}
