[opheldu,unfinished_guthixbook]
switch_obj(last_useitem) {
    case holy_book_g_page1 :
        if(%horror_balancepage1 = ^true) {
            mes("You have already added this page to the book.");
            return;
        }
        %horror_balancepage1 = ^true;
        inv_del(inv, holy_book_g_page1, 1);
        mes("You add the page to the book...");
        ~check_balancebook_complete;
        return;
    case holy_book_g_page2 :
        if(%horror_balancepage2 = ^true) {
            mes("You have already added this page to the book.");
            return;
        }
        %horror_balancepage2 = ^true;
        inv_del(inv, holy_book_g_page2, 1);
        mes("You add the page to the book...");
        ~check_balancebook_complete;
        return;
    case holy_book_g_page3 :
        if(%horror_balancepage3 = ^true) {
            mes("You have already added this page to the book.");
            return;
        }
        %horror_balancepage3 = ^true;
        inv_del(inv, holy_book_g_page3, 1);
        mes("You add the page to the book...");
        ~check_balancebook_complete;
        return;
    case holy_book_g_page4 :
