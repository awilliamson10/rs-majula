[opobj3,zamorakbook_complete]
// https://www.youtube.com/watch?v=v0g55VLG088&t=60s
if(~obj_gettotal(zamorakbook_complete) > 0) {
    mes("You do not need more than one unholy book.");
    return;
}
@pickup_obj;

[opobj3,saradominbook_complete]
if(~obj_gettotal(saradominbook_complete) > 0) {
    mes("You do not need more than one holy book.");
    return;
}
@pickup_obj;

[opobj3,guthixbook_complete]
if(~obj_gettotal(guthixbook_complete) > 0) {
    mes("You do not need more than one book of balance.");
    return;
}
@pickup_obj;

[opobj3,unfinished_zamorakbook]
if(~obj_gettotal(unfinished_zamorakbook) > 0) {
    mes("You do not need more than one incomplete book.");
    return;
}
@pickup_obj;

[opobj3,unfinished_saradominbook]
if(~obj_gettotal(unfinished_saradominbook) > 0) {
    mes("You do not need more than one incomplete book.");
    return;
}
@pickup_obj;

[opobj3,unfinished_guthixbook]
if(~obj_gettotal(unfinished_guthixbook) > 0) {
    mes("You do not need more than one incomplete book.");
    return;
}
@pickup_obj;

[opheldu,unfinished_zamorakbook]
switch_obj(last_useitem) {
    case holy_book_z_page1 :
        if(%horror_unholypage1 = ^true) {
            mes("You have already added this page to the book.");
            return;
        }
        %horror_unholypage1 = ^true;
        inv_del(inv, holy_book_z_page1, 1);
        mes("You add the page to the book...");
        ~check_unholybook_complete;
        return;
    case holy_book_z_page2 :
        if(%horror_unholypage2 = ^true) {
            mes("You have already added this page to the book.");
            return;
        }
        %horror_unholypage2 = ^true;
        inv_del(inv, holy_book_z_page2, 1);
        mes("You add the page to the book...");
        ~check_unholybook_complete;
        return;
    case holy_book_z_page3 :
        if(%horror_unholypage3 = ^true) {
            mes("You have already added this page to the book.");
            return;
        }
        %horror_unholypage3 = ^true;
        inv_del(inv, holy_book_z_page3, 1);
        mes("You add the page to the book...");
        ~check_unholybook_complete;
        return;
    case holy_book_z_page4 :
        if(%horror_unholypage4 = ^true) {
            mes("You have already added this page to the book.");
            return;
        }
        %horror_unholypage4 = ^true;
        inv_del(inv, holy_book_z_page4, 1);
        mes("You add the page to the book...");
        ~check_unholybook_complete;
        return;
}
if(oc_category(last_useitem) = category_759) {
    mes("This page does not appear to come from this book.");
    return;
}
if(last_useitem = stringsnake) {
    mes("You cannot bless symbols with an incomplete book.");
    return;
}
~displaymessage(^dm_default);

