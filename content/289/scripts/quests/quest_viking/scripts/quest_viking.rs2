[proc,generate_viking_name]
%godbook_multi = setbit_range_toint(%godbook_multi, random(16), ^viking_name_lower1, ^viking_name_upper1);
%godbook_multi = setbit_range_toint(%godbook_multi, random(16), ^viking_name_lower2, ^viking_name_upper2);

[proc,get_viking_name]()(string)
def_string $s1 = "Rak";
def_string $s2 = "lak";

switch_int(getbit_range(%godbook_multi, ^viking_name_lower1, ^viking_name_upper1)) {
    case 1 : $s1 = "Bal";
    case 2 : $s1 = "Bar";
    case 3 : $s1 = "Dal";
    case 4 : $s1 = "Dar";
    case 5 : $s1 = "Den";
    case 6 : $s1 = "Dok";
    case 7 : $s1 = "Jar";
    case 8 : $s1 = "Jik";
    case 9 : $s1 = "Lar";
    case 10 : $s1 = "Ral";
    case 11 : $s1 = "Ril";
    case 12 : $s1 = "Sig";
    case 13 : $s1 = "Tal";
    case 14 : $s1 = "Thor";
    case 15 : $s1 = "Ton";
}

switch_int(getbit_range(%godbook_multi, ^viking_name_lower2, ^viking_name_upper2)) {
    case 1 : $s2 = "dar";
    case 2 : $s2 = "dor";
    case 3 : $s2 = "dur";
    case 4 : $s2 = "kal";
    case 5 : $s2 = "kar";
    case 6 : $s2 = "kir";
    case 7 : $s2 = "kur";
    case 8 : $s2 = "lah";
    case 9 : $s2 = "lim";
    case 10 : $s2 = "lor";
    case 11 : $s2 = "rak";
    case 12 : $s2 = "tin";
    case 13 : $s2 = "ton";
    case 14 : $s2 = "tor";
    case 15 : $s2 = "vald";
}


return (append($s1, $s2));

[queue,viking_quest_complete]
stat_advance(attack, 28124);
stat_advance(defence, 28124);
stat_advance(strength, 28124);
stat_advance(hitpoints, 28124);
stat_advance(woodcutting, 28124);
stat_advance(fletching, 28124);
stat_advance(fishing, 28124);
stat_advance(crafting, 28124);
stat_advance(agility, 28124);
stat_advance(thieving, 28124);
%viking = ^viking_complete;
session_log(^log_adventure, "Quest complete: The Fremennik Trials");
queue(fremennik_name, 0, 0);
~send_quest_complete(questlist:viking, viking_helmet, 150, ^viking_questpoints, "You have completed the\\nTrials of the Fremmenik Quest!");

[queue,fremennik_name]
~generate_viking_name;
if(npc_find(coord, viking_brundt, 10, 0) = true) {
    ~chatnpc("<p,neutral>From this day onward, you are outerlander no more! In honour of your acceptance into the Fremennik You gain a new name to be known as; You will now be called <~get_viking_name>.");
}
