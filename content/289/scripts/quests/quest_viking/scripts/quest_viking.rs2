[oploc1,viking_fencegate_l] @open_viking_fencegate(^left);
[oploc1,viking_fencegate_r] @open_viking_fencegate(^right);

[label,open_viking_fencegate](int $side)
if(%viking < ^viking_complete) {
    mes("Only Fremenniks may pass this gate.");
    return;
}
def_coord $loc_coord = loc_coord;
loc_add(0_41_57_57_49, inviswall, 1, loc_shape, 3);
loc_add(0_41_57_57_50, inacviking_fencegate_l, 0, loc_shape, 3);
loc_add(0_41_57_58_49, inviswall, 1, loc_shape, 3);
loc_add(0_41_57_57_51, inacviking_fencegate_r, 0, loc_shape, 3);
sound_synth(door_open, 1, 0); // gate_open
if(coordx(coord) < coordx($loc_coord)) {
    p_teleport($loc_coord);
    p_delay(0);
}
if(coordz(coord) > coordz($loc_coord)) {
    p_teleport($loc_coord);
} else {
    p_teleport(movecoord($loc_coord, 0, 0, 1));
}

[oploc1,viking_chest_closed]
~open_chest(viking_chest_open);

[oploc1,viking_chest_open]
~close_chest(viking_chest_closed);

[oploc2,viking_chest_open]
mes("You search the chest...");
p_delay(3);
def_int $rand = random(128);
// 151 atttempts on osrs, 18 on outcome 1, 133 for outcome 2, 1 for outcome 3
if($rand < 16) {
    mes("You don't find anything interesting.");
} else if($rand < 127) {
    mes("You find nothing inside.");
} else {
    mes("You think you find something nice...");
    mes("But it turns out to be nothing.");
}

[proc,get_viking_swensen_progress]()(int)
return (getbit_range(%viking_bits, ^viking_swensen_start, ^viking_swensen_end));

[proc,set_viking_swensen_progress](int $prog)
%viking_bits = setbit_range_toint(%viking_bits, $prog, ^viking_swensen_start, ^viking_swensen_end);

