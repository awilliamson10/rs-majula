[oplocu,viking_small_table_frozen]
switch_obj(last_useitem) {
    case viking_pointless_magnet : mes("You use the magnet on the table. It gets slightly colder.");
    case viking_bucket_empty : mes("Your empty bucket gets very cold on the icy table.");
    case viking_jug_empty : mes("Your empty jug gets very cold on the icy table.");
    case viking_bucket_1, viking_bucket_2, viking_bucket_3, viking_bucket_4, viking_bucket_5 :
        mes("The icy table immediately freezes the water in your bucket.");
        inv_setslot(inv, last_useslot, viking_bucket_frozen, 1);
    case viking_jug_1, viking_jug_2, viking_jug_3 :
        mes("The icy table immediately freezes the water in your jug.");
        inv_setslot(inv, last_useslot, viking_jug_frozen, 1);
    case viking_airtight_vase_water :
        mes("The icy table immediately freezes the water in your vase.");
        inv_setslot(inv, last_useslot, viking_airtight_vase_frozen, 1);
    case viking_airtight_vase_with_lid_water :
        mes("The water expands as it freezes, and shatters the vase.");
        mes("You are left with a key encased in ice.");
        inv_del(inv, viking_airtight_vase_with_lid_water, 1);
        inv_add(inv, viking_key_in_ice, 1);
    case viking_bucket_frozen, viking_jug_frozen, viking_airtight_vase_frozen, viking_airtight_vase_with_lid_frozen :
        mes("It's not gonna get any colder!");
    case default : ~displaymessage(^dm_default);
}

[oploc1,viking_cupboardhigh]
p_arrivedelay;
anim(human_openhighcupboard, 0);
sound_synth(cupboard_open, 1, 0);
p_delay(0);
loc_change(viking_cupboardopen_high, 300);

[oploc1,viking_cupboardopen_high]
p_arrivedelay;
anim(human_closehighcupboard, 0);
sound_synth(cupboard_close, 1, 0);
p_delay(0);
loc_change(viking_cupboardhigh, 300);

[oploc2,viking_cupboardopen_high]
mes("You search the cupboard...");
p_delay(3);
if(inv_total(inv, viking_bucket_empty) > 0) {
    mes("You find nothing of interest.");
    return;
}
inv_add(inv, viking_bucket_empty, 1);
mes("You find a bucket with a number five painted on it.");

[oploc1,viking_seer_chest_closed_scales]
if(testbit(%viking_bits, ^viking_seerdoor_unlocked_chest) = ^true) {
    if(inv_total(inv, viking_airtight_vase) > 0) {
        mes("There is nothing left inside the chest.");
        return;
    }
    mes("You take a strange looking vase out of the chest.");
    inv_add(inv, viking_airtight_vase, 1);
    return;
}
~mesbox("This chest is securely locked shut. There is some kind of balance attached to the lock, and a number four is painted just above it.");

[oplocu,viking_seer_chest_closed_scales]
switch_obj(last_useitem) {
    case viking_jug_empty, viking_jug_1, viking_jug_2, viking_jug_3 :
        anim(human_openchest, 0);
        mes("You place the jug on the scale.");
        mes("It is too light to balance it properly.");
    case viking_bucket_empty, viking_bucket_1, viking_bucket_2, viking_bucket_3 :
        anim(human_openchest, 0);
        mes("You place the jug on the scale.");
        mes("It is too light to balance it properly.");
    case viking_bucket_4 :
        mes("You place the bucket on the scale.");
        mes("It is a perfect counterweight and balances precisely.");
        mes("You take a strange looking vase out of the chest.");
        anim(human_openchest, 0);
        inv_add(inv, viking_airtight_vase, 1);
        %viking_bits = setbit(%viking_bits, ^viking_seerdoor_unlocked_chest);
    case viking_bucket_5 :
        anim(human_openchest, 0);
        mes("You place the bucket on the scale.");
        mes("It is too heavy to balance it properly.");
    case viking_pointless_pick :
        mes("You might be able to break the chest open using this pick...");
        mes("...if you stood here tapping at it for twenty years or so.");
    case viking_pointless_magnet :
        mes("You use the magnet on the chest. The scales wobble a bit.");
    case default : ~displaymessage(^dm_default);
}

[oplocu,viking_seer_range]
switch_obj(last_useitem) {
    case viking_pointless_shiptoy :
        mes("You put the toy ship on the range. It burns.");
        inv_setslot(inv, last_useslot, ashes, 1);
    case viking_pointless_thread :
        mes("You put the thread on the range. It burns.");
        inv_setslot(inv, last_useslot, ashes, 1);
    case viking_pointless_magnet :
        mes("You use the magnet on the range. It gets slightly warmer.");
    case viking_bucket_frozen :
        mes("You place the frozen bucket on the range. The ice turns to steam.");
        inv_setslot(inv, last_useslot, viking_bucket_empty, 1);
    case viking_jug_frozen :
        mes("You place the frozen jug on the range. The ice turns to steam.");
        inv_setslot(inv, last_useslot, viking_jug_empty, 1);
    case viking_airtight_vase_frozen :
        mes("You place the frozen vase on the range. The ice turns to steam.");
        inv_setslot(inv, last_useslot, viking_airtight_vase, 1);
    case viking_red_herring :
        inv_del(inv, viking_red_herring, 1);
        inv_add(inv, herring, 1);
        inv_add(inv, viking_red_splat, 1);
        ~mesbox("As you cook the herring on the stove, the colouring on it peels off separately as a red sticky goop...");
    case viking_key_in_ice :
        mes("The heat of the range melts the ice around the key.");
        inv_setslot(inv, last_useslot, viking_key, 1);
    case default : ~displaymessage(^dm_default);
}

[opheld1,viking_airtight_vase]
~mesbox("You shake the strangely shaped Vase. From the sound of it there is something metallic inside, but the neck of the vase is too narrow for it to come out.");

[opheld1,viking_airtight_vase_water]
~mesbox("You shake the strangely shaped Vase. The water inside it sloshes around a little. Some spills out of the neck of the vase.");

[opheld1,viking_airtight_vase_frozen]
~mesbox("You shake the strangely shaped Vase. Whatever is at the bottom of it is packed with ice and does not rattle.");

