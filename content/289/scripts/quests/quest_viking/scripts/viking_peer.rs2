inv_del(inv, viking_bucket_4, ^max_32bit_int);
inv_del(inv, viking_bucket_3, ^max_32bit_int);
inv_del(inv, viking_bucket_2, ^max_32bit_int);
inv_del(inv, viking_bucket_1, ^max_32bit_int);
inv_del(inv, viking_bucket_empty, ^max_32bit_int);
inv_del(inv, viking_bucket_frozen, ^max_32bit_int);
inv_del(inv, viking_jug_3, ^max_32bit_int);
inv_del(inv, viking_jug_2, ^max_32bit_int);
inv_del(inv, viking_jug_1, ^max_32bit_int);
inv_del(inv, viking_jug_empty, ^max_32bit_int);
inv_del(inv, viking_jug_frozen, ^max_32bit_int);
inv_del(inv, viking_airtight_vase, ^max_32bit_int);
inv_del(inv, viking_airtight_vase_water, ^max_32bit_int);
inv_del(inv, viking_airtight_vase_frozen, ^max_32bit_int);
inv_del(inv, viking_vase_lid, ^max_32bit_int);
inv_del(inv, viking_airtight_vase_with_lid, ^max_32bit_int);
inv_del(inv, viking_airtight_vase_with_lid_frozen, ^max_32bit_int);
inv_del(inv, viking_airtight_vase_with_lid_water, ^max_32bit_int);
inv_del(inv, viking_key_in_ice, ^max_32bit_int);
inv_del(inv, viking_red_herring, ^max_32bit_int);
