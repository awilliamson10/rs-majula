[opnpc1,viking_peer]
def_int $op;
def_string $s;
if(%viking = ^viking_not_started) {
    ~chatnpc("<p,neutral>I have no interest in talking to you just now outerlander.");
    return;
} else if(%viking < ^viking_complete) {
    if(~get_viking_thorvald_progress > ^thorvald_not_started & ~get_viking_thorvald_progress < ^thorvald_complete 
        & ~get_viking_sigmund_progress > ^sigmund_not_started & ~get_viking_sigmund_progress < ^sigmund_complete) {
        $op = ~p_choice3("Ask about the Merchant's trial", 1, "Ask about becoming a Fremennik", 3, "Ask about depositing your equipment", 2);
    } else if(~get_viking_thorvald_progress > ^thorvald_not_started & ~get_viking_thorvald_progress < ^thorvald_complete) {
        $op = ~p_choice2("Ask about becoming a Fremennik", 3, "Ask about depositing your equipment", 2);
    } else if (~get_viking_sigmund_progress > ^sigmund_not_started & ~get_viking_sigmund_progress < ^sigmund_complete) {
        $op = ~p_choice2("Ask about the Merchant's trial", 1, "Ask about becoming a Fremennik", 3);
    }
    if($op = 2) @peer_equipment_deposit;
    if($op = 1) @peer_merchant_trial;
    switch_int(~get_viking_peer_progress) {
        case ^peer_complete :
            ~chatplayer("<p,quiz>So you will vote for me at the council?");
            ~chatnpc("<p,neutral>Absolutely, outerlander. Your wisdom in passing my test marks you as worthy in my eyes.");
        case ^peer_started, ^peer_completed_riddle : @peer_house_check;
        case ^peer_not_started :
            ~chatnpc("<p,neutral>Hello outerlander. What do you want?");
            ~chatplayer("<p,quiz>Hello. I'm looking for members of the council of elders to vote for me to become a Fremennik.");
            ~chatnpc("<p,neutral>Are you now? Well that is interesting. Usually outerlanders do not concern themselves with our ways like that.");
            ~chatnpc("<p,neutral>I am one of the members of the council of elders, and should you be able to prove to me that you have something to offer my clan");
            ~chatnpc("<p,neutral>I will vote in your favour at the next meeting.");
            ~chatplayer("<p,quiz>How can I prove that to you?");
            ~chatnpc("<p,neutral>Well, I have but a simple test. This building behind me is my house. Inside I have constructed a puzzle.");
            ~chatnpc("<p,neutral>As a Seer to the clan, I value intelligence very highly, so you may think of it as an intelligence test of sorts.");
            ~chatplayer("<p,quiz>An intelligence test? I thought barbarians were stupid!");
            ~chatnpc("<p,neutral>That is the opinion that outerlanders usually hold of my people, it is true. But that is because people often confuse knowledge with wisdom.");
            ~chatnpc("<p,neutral>My puzzle tests not what you know, but what you can work out. All members of our clan have been tested when they took their trials.");
            ~chatplayer("<p,quiz>So what exactly does this puzzle consist of, then?");
            ~chatnpc("<p,neutral>Well, firstly you must enter my house with no items, weapons or armour. Then it is a simple matter of entering through one door and leaving by the other.");
            ~chatplayer("<p,neutral>I can't take anything in there with me?");
            ~chatnpc("<p,neutral>That is correct outerlander. Everything you need to complete the puzzle you will find inside the building. Nothing more.");
            ~chatnpc("<p,neutral>So what say you outerlander? You think you have the wit to earn yourself my vote?");
            $op = ~p_choice2("Yes", 1, "No", 2);
            if($op = 2) {
                ~chatplayer("<p,neutral>No, thinking about stuff isn't really my 'thing'. I'd rather go kill something. I'll find someone else to vote for me.");
                ~chatnpc("<p,neutral>As you wish, outerlander.");
                return;
            }
            ~set_viking_peer_progress(^peer_started);
            %viking_bits = setbit_range_toint(%viking_bits, random(6), ^viking_seerdoor_start, ^viking_seerdoor_end);
            ~chatplayer("<p,neutral>Yes, I accept your challenge. I have one small question, however...");
            ~chatnpc("<p,quiz>Yes, outerlander?");
            ~chatplayer("<p,quiz>Well... you say I can bring nothing with me when I enter your house...");
            ~chatnpc("<p,quiz>Yes, outerlander?");
            ~chatplayer("<p,quiz>Well.....");
            ~chatnpc("<p,quiz>Yes, outerlander?");
            ~chatplayer("<p,sad>Where is the nearest bank?");
            ~chatnpc("<p,neutral>Ah, I see your problem outerlander. The nearest bank to here is the place known to outerlanders as the Seers Village. It is some way South.");
            ~chatnpc("<p,neutral>I do however have an alternative, should you wish to take it.");
            ~chatplayer("<p,quiz>And what is that?");
            ~chatnpc("<p,neutral>I can store all the weapons, armour and items that you have upon you directly into your bank account.");
            ~chatnpc("<p,neutral>This will tax what little magic I possess however, so you will have to manually travel to the bank to withdraw them again.");
            ~chatnpc("<p,quiz>What say you outerlander? you wish me to do this for you?");
            @peer_prompt_bank;
    }
} else if(%viking = ^viking_complete) {
    ~chatplayer("<p,happy>Hello Peer.");
    ~chatnpc("<p,quiz>Greetings to you <text_gender("brother", "sister")> <~get_viking_name>! What brings you to see me again?");
    $op = ~p_choice2("Can you tell my future?", 1, "Nothing really.", 2);
    if($op = 2) {
        ~chatplayer("<p,neutral>Nothing really, I just stopped by to say hello.");
        ~chatnpc("<p,neutral>Well, hello to you too!");
        return;
    }
    ~chatplayer("<p,quiz>I was wondering if you could give me a reading on my future...?");
    ~chatnpc("<p,neutral>Ah, you would like a prediction? I do not see that that would be so difficult... wait a moment...");
    if_close;
    p_delay(3);
    $op = random(6);
    if($op = 0) {
        $op = random(10);
        if($op = 0) $s = "fire giant";
        else if($op = 1) $s = "ghost";
        else if($op = 2) $s = "goblin";
        else if($op = 3) $s = "green dragon";
        else if($op = 4) $s = "hobgoblin";
        else if($op = 5) $s = "lesser demon";
        else if($op = 6) $s = "moss giant";
        else if($op = 7) $s = "ogre";
        else if($op = 8) $s = "skeleton";
        else if($op = 9) $s = "zombie";
        ~chatnpc("<p,neutral>Here is your prediction: The enemy called <$s> is your lucky totem this day.");
    } else if($op = 1) {
        $op = random(10);
        if($op = 0) $s = "battleaxe";
        else if($op = 1) $s = "crossbow";
        else if($op = 2) $s = "dagger";
        else if($op = 3) $s = "javelin";
        else if($op = 4) $s = "long sword";
        else if($op = 5) $s = "mace";
        else if($op = 6) $s = "scimitar";
        else if($op = 7) $s = "short sword";
        else if($op = 8) $s = "spear";
        else if($op = 9) $s = "warhammer";
        ~chatnpc("<p,neutral>Here is your prediction: The stars tell me that you should use a <$s> in combat today.");
    } else if($op = 2) {
        $op = random(9);
        if($op = 0) $s = "Al Kharid";
        else if($op = 1) $s = "Ardougne";
        else if($op = 2) $s = "Burthorpe";
        else if($op = 3) $s = "Canifis";
        else if($op = 4) $s = "Falador";
        else if($op = 5) $s = "Karamja";
        else if($op = 6) $s = "Varrock";
        else if($op = 7) $s = "The Wilderness";
        else if($op = 8) $s = "Yanille";
        ~chatnpc("<p,neutral>Here is your prediction: The place called <$s> will be worth your time to visit.");
    } else if($op = 3) {
        $op = random(10);
        if($op = 0) $s = "Agility";
        else if($op = 1) $s = "Cooking";
        else if($op = 2) $s = "Crafting";
        else if($op = 3) $s = "Fishing";
        else if($op = 4) $s = "Fletching";
        else if($op = 5) $s = "Herblore";
        else if($op = 6) $s = "Mining";
        else if($op = 7) $s = "Runecrafting";
        else if($op = 8) $s = "Smithing";
        else if($op = 9) $s = "Thieving";
        ~chatnpc("<p,neutral>Here is your prediction: You would be wise to train the skill <$s> today.");
    } else if($op = 4) {
        $op = random(10);
        if($op = 0) $s = "black";
        else if($op = 1) $s = "blue";
        else if($op = 2) $s = "brown";
        else if($op = 3) $s = "cyan";
        else if($op = 4) $s = "green";
        else if($op = 5) $s = "pink";
        else if($op = 6) $s = "purple";
        else if($op = 7) $s = "red";
        else if($op = 8) $s = "white";
        else if($op = 9) $s = "yellow";
        ~chatnpc("<p,neutral>Here is your prediction: The colour <$s> will bring you luck this day.");
    } else if($op = 5) {
        $op = random(10);
        if($op = 0) $s = "one";
        else if($op = 1) $s = "two";
        else if($op = 2) $s = "three";
        else if($op = 3) $s = "four";
        else if($op = 4) $s = "five";
        else if($op = 5) $s = "six";
        else if($op = 6) $s = "seven";
        else if($op = 7) $s = "eight";
        else if($op = 8) $s = "nine";
        else if($op = 9) $s = "ten";
        ~chatnpc("<p,neutral>Here is your prediction: You will find luck today with the number <$s>.");
    }
}

[label,peer_house_check]
~chatplayer("<p,quiz>So I can bring nothing with me when I enter your house?");
~chatnpc("<p,neutral>That is correct outerlander, but as I say, I can use my small skill in magic to send your items directly into your bank account from here.");
~chatnpc("<p,neutral>You will need to manually go to the bank to withdraw them again however. Would you like me to perform this small spell upon you, outerlander?");
@peer_prompt_bank;

[label,peer_prompt_bank]
def_int $op = ~p_choice2("Yes", 1, "No", 2);
if($op = 2) {
    ~chatplayer("<p,angry>No thanks. Nobody touches my stuff but me!");
    ~chatnpc("<p,neutral>As you wish, outerlander.");
    ~chatnpc("<p,neutral>You may attempt my little task when you have deposited your equipment in the bank.");
    return;
}
~chatplayer("<p,happy>Yes, thank you!");
@peer_deposit;

[label,peer_equipment_deposit]
~chatplayer("<p,neutral>Hello there! Thorvald tells me you can deposit my equipment directly into my bank account for me...?");
~chatnpc("<p,neutral>That is correct outerlander, but you will need to go and retrieve your equipment from your bank account yourself, manually.");
~chatnpc("<p,neutral>Alas, my spell is not very accurate, so it will deposit everything you have upon you into your bank, not just your armour and weapons.");
def_int $op = ~p_choice2("Bank your equipment", 1, "Don't bank your equipment", 2);
if($op = 2) {
    ~chatplayer("<p,neutral>No thanks, I'll just go to the bank and sort my inventory out myself.");
    return;
}
@peer_deposit;

[label,peer_deposit]
def_int $size = inv_size(inv);
def_int $dep_count;
def_int $i = 0;
def_obj $obj;
def_int $fail = ^false;
while ($i < $size) {
    $obj = inv_getobj(inv, $i);
    if ($obj ! null) {
        if (~bank_check_allowed($obj, ^false) = true) {
            if(~bank_deposit_request(inv, $obj, inv_total(inv, $obj), $i, ^false) = true) {
                $dep_count = add($dep_count, 1);
            } else {
                $fail = ^true;
            }
        } else {
            $fail = ^true;
        }
    }
    $i = add($i, 1);
}

$size = inv_size(worn);
$i = 0;
while ($i < $size) {
    $obj = inv_getobj(worn, $i);
    if ($obj ! null) {
        if (~bank_check_allowed($obj, ^false) = true) {
            if(~bank_deposit_request(worn, $obj, inv_total(worn, $obj), $i, ^false) = true) {
                $dep_count = add($dep_count, 1);
            } else {
                $fail = ^true;
            }
        } else {
            $fail = ^true;
        }
    }
    $i = add($i, 1);
}

if($fail = ^true) {
    if($dep_count > 0) mes("Some of your items cannot be stored in the bank.");
    else mes("Your items cannot be stored in the bank.");
    ~chatnpc("<p,sad>I am sorry outerlander, the spell is not working.");
    return;
}
~chatnpc("<p,neutral>The task is done. I wish you luck with your test, outerlander.");


[label,peer_merchant_trial]
if(inv_total(inv, viking_promissary_note3) > 0) {
    ~chatplayer("<p,quiz>Can I have a weather forecast now please?");
    ~chatnpc("<p,neutral>I have already told you outerlander; You may have a reading from me when I have a signed contract from a warrior guaranteeing my protection.");
    ~chatplayer("<p,happy>Yeah, I know; I have one right here from Thorvald.");
    inv_del(inv, viking_promissary_note3, 1);
    inv_add(inv, viking_weather_forecast, 1);
    ~chatnpc("<p,shock>You have not only persuaded one of the Fremennik to act as a servant to me, but you have enlisted the aid of mighty Thorvald himself???");
    ~chatnpc("<p,happy>You may take this forecast with my blessing outerlander. You have offered me the greatest security I can imagine.");
    return;
}
if(inv_total(inv, viking_weather_forecast) > 0) {
    ~chatplayer("<p,quiz>So, about this forecast...");
    ~chatnpc("<p,neutral>Yes, outerlander?");
    ~chatplayer("<p,neutral>I still don't know why you didn't just let me have one anyway in the first place. Surely it means nothing to you?");
    ~chatnpc("<p,neutral>That is not true, outerlander. Although I see glimpses of the future all of the time, using my powers brings the attention of the gods to me.");
    ~chatnpc("<p,neutral>Some of the gods are spiteful and cruel, and I fear if I use my powers too much then I will meet with unpredictable accidents. This is why I needed protection.");
    ~chatplayer("<p,confused>Okay... I... think I understand...");
    return;
}
switch_int(~get_viking_sigmund_progress) {
    case ^sigmund_spoke_manni :
        ~chatplayer("<p,quiz>I don't suppose you have any idea where I could find the longhall barkeep's legendary cocktail, do you?");
        ~chatnpc("<p,neutral>I'm afraid not, outerlander.");
    case ^sigmund_spoke_thorvald :
        // a few npcs use your for some reason, bad copy paste from thorvald probably...
        ~chatplayer("<p,quiz>I don't suppose you have any idea where I could find the token to allow your seat at the champions table?");
        ~chatnpc("<p,neutral>I'm afraid not, outerlander.");
    case ^sigmund_spoke_seer :
        ~chatplayer("<~merchant_question_text>");
        ~chatnpc("<p,neutral>If I did, then I would simply have asked them myself now, wouldn't I, outerlander?");
    case ^sigmund_spoke_swensen :
        ~chatplayer("<~merchant_question_text>");
        ~chatnpc("<p,confused>Er.... Yes, because I AM the Fremennik Seer.");
        ~chatplayer("<p,quiz>Can I have a weather forecast then please?");
        ~chatnpc("<p,neutral>You require a divination of the weather? This is a simple matter for me, but I will require something in return from you for this small service.");
        ~chatplayer("<p,sad>I knew you were going to say that...");
        ~set_viking_sigmund_progress(^sigmund_spoke_seer); // recheck this...
        ~chatnpc("<p,neutral>Do not fret, outerlander; it is a fairly simple matter. I require a bodyguard for protection. Find someone willing to offer me this service.");
        ~chatplayer("<p,quiz>That's all?");
        ~chatnpc("<p,neutral>That is all.");
    case default :
        ~chatplayer("<~merchant_question_text>");
        ~chatnpc("<p,neutral>I'm afraid not, outerlander.");
}

[oploc1,viking_seers_door1]
def_boolean $entering = ~check_axis(coord, loc_coord, loc_angle);
if($entering = false) {
    ~mesbox("If you leave by this door you will fail this trial.|Press continue to go through the door anyway.");
    ~clear_peer_trial_items;
    ~open_and_close_door2(viking_door_inactive, $entering, door_open);
    return;
}
if(%viking = ^viking_complete) {
    ~chatplayer("<p,neutral>I don't really fancy going through that annoying puzzle room again now that I am a member of the Fremennik.");
} else if(~get_viking_peer_progress = ^peer_complete) {
    ~chatplayer("<p,neutral>I don't really fancy going through that annoying puzzle room again now that I have the Seer's vote.");
} else if(~get_viking_peer_progress > ^peer_started) {
    if(inv_freespace(inv) ! inv_size(inv) | inv_freespace(worn) ! inv_size(worn)) {
        if(npc_find(coord, viking_peer, 7, 0) = true) @peer_house_check;
        return;
    }
    ~open_and_close_door2(viking_door_inactive, $entering, door_open);
} else if(~get_viking_peer_progress = ^peer_started) {
    ~mesbox("There is a combination lock on this door. Above the lock you can see that there is a metal plaque with a riddle on it.");
    switch_int(~p_choice3_header("Read the riddle", 1, "Solve the riddle", 2, "Forget it", 3, "What would you like to do?")) {
        case 1 : @viking_seer_read_riddle;
        case 2 : @viking_seer_enter_riddle;
        case 3 :
            mes("You leave the riddle for later.");
    }
} else if(~get_viking_peer_progress = ^peer_not_started) {
    if(npc_find(coord, viking_peer, 7, 0) = true) {
        ~chatnpc("<p,angry>Hey! Outerlander! That is my house! Who do you think you are to just barge into my home without asking?");
        ~chatplayer("<p,neutral>Um... My name is <displayname()>.");
        ~chatnpc("<p,angry>It was a rhetorical question, outerlander. Now get lost. I do not appreciate intruders in my home.");
    }
    return;
}

[label,viking_seer_read_riddle]
switch_int(getbit_range(%viking_bits, ^viking_seerdoor_start, ^viking_seerdoor_end)) {
    case 0 :
        ~mesbox("My first is in mage, but not in wizard.|My second in goblin, and also in lizard.|My third in night, but not in the day.|My last is in fields, but not in the hay.");
        // https://web.archive.org/web/20070103233159im_/http://www.runeweb.net/rathofdoom/quests/fremenniktrials/10.png
        ~mesbox("My whole is the most powerful|tool you will possess.||What am I?");
    case 1 :
        ~mesbox("My first is in tar, but not in a swamp.|My second in fire, but not in a camp.|My third is in eagle, but never in air.|My last is in hate, but also in care.");
        ~mesbox("My whole wears more rings the older I get.|What am I?");
    case 2 :
        ~mesbox("My first is in the well, but not at sea.|My second in 'I', but not in 'me'.|My third in flies, but insects not found.|My last is in earth, but not in the ground.");
        ~mesbox("My whole when stolen from you causes you death.|What am I?");
    case 3 :
        ~mesbox("My first is in fish, but not in the sea.|My second in birds, but not in a tree.|My third is in doors, but not in a hall.|My last is everything, but nothing at all.");
        ~mesbox("My whole cannot die as long as it has food.|What am I?");
    case 4 :
        ~mesbox("My first is in water, and also in tea.|My second is in fish, but not in the sea.|My third is in mountains, but not underground.|My last is in strike, but not like in pound.");
        ~mesbox("My whole crushes mountains, drains rivers, and destroys civilisations.|All that live fear my passing.|What am I?");
    case 5 :
        ~mesbox("My first is in wizard, but not in a mage.|My second in jail, but not in a cage.|My third is in anger, but not in a rage.|My last in a drawing, but not on a page.");
        ~mesbox("My whole helps to make bread, let birds fly and boats sail.|What am I?");
}
@viking_seer_enter_riddle;

// functionally (nearly) the same as the tribal door
[if_button,combolockdoor:com_57]
if_close;
def_int $solved = ^false;
def_int $riddle_id = getbit_range(%viking_bits, ^viking_seerdoor_start, ^viking_seerdoor_end);
if(~get_viking_peer_progress < ^peer_completed_riddle) {
    if($riddle_id = 0) {
        if(~get_viking_door_lock(1) = 12 & ~get_viking_door_lock(2) = 8 & ~get_viking_door_lock(3) = 13 & ~get_viking_door_lock(4) = 3) { // MIND
            $solved = ^true;
        }
    } else if($riddle_id = 1) {
        if(~get_viking_door_lock(1) = 19 & ~get_viking_door_lock(2) = 17 & ~get_viking_door_lock(3) = 4 & ~get_viking_door_lock(4) = 4) { // TREE
            $solved = ^true;
        }
    } else if($riddle_id = 2) {
        if(~get_viking_door_lock(1) = 11 & ~get_viking_door_lock(2) = 8 & ~get_viking_door_lock(3) = 5 & ~get_viking_door_lock(4) = 4) { // LIFE
            $solved = ^true;
        }
    } else if($riddle_id = 3) {
        if(~get_viking_door_lock(1) = 5 & ~get_viking_door_lock(2) = 8 & ~get_viking_door_lock(3) = 17 & ~get_viking_door_lock(4) = 4) { // FIRE
            $solved = ^true;
        }
    } else if($riddle_id = 4) {
        if(~get_viking_door_lock(1) = 19 & ~get_viking_door_lock(2) = 8 & ~get_viking_door_lock(3) = 12 & ~get_viking_door_lock(4) = 4) { // TIME
            $solved = ^true;
        }
    }else if($riddle_id = 5) {
        if(~get_viking_door_lock(1) = 22 & ~get_viking_door_lock(2) = 8 & ~get_viking_door_lock(3) = 13 & ~get_viking_door_lock(4) = 3) { // WIND
            $solved = ^true;
        }
    }
    if($solved = ^true) {
        ~set_viking_peer_progress(^peer_completed_riddle);
        mes("You have solved the riddle!");
    } else mes("You have failed to solve the riddle.");
    return;
} 

[if_button,combolockdoor:com_47] @viking_door_combo(1, -1);
[if_button,combolockdoor:com_49] @viking_door_combo(2, -1);
[if_button,combolockdoor:com_51] @viking_door_combo(3, -1);
[if_button,combolockdoor:com_53] @viking_door_combo(4, -1);

[if_button,combolockdoor:com_48] @viking_door_combo(1, 1);
[if_button,combolockdoor:com_50] @viking_door_combo(2, 1);
[if_button,combolockdoor:com_52] @viking_door_combo(3, 1);
[if_button,combolockdoor:com_54] @viking_door_combo(4, 1);

[label,viking_seer_enter_riddle]
%temp = 0;
if_openmain(combolockdoor);
if_settext(combolockdoor:com_43, "A");
if_settext(combolockdoor:com_44, "A");
if_settext(combolockdoor:com_45, "A");
if_settext(combolockdoor:com_46, "A");

[proc,get_viking_door_lock](int $lock_index)(int)
return (getbit_range(%temp, calc(5 * $lock_index - 4), calc(5 * $lock_index)));

[label,viking_door_combo](int $lock_index, int $change)
def_int $current_stage = ~get_viking_door_lock($lock_index);
def_int $stage = ~calc_tribaldoor_value($current_stage, $change);
%temp = setbit_range_toint(%temp, $stage, calc(5 * $lock_index - 4), calc(5 * $lock_index));
switch_int($lock_index) {
    case 1 : if_settext(combolockdoor:com_43, enum(int, string, alphabet, $stage));
    case 2 : if_settext(combolockdoor:com_44, enum(int, string, alphabet, $stage));
    case 3 : if_settext(combolockdoor:com_45, enum(int, string, alphabet, $stage));
    case 4 : if_settext(combolockdoor:com_46, enum(int, string, alphabet, $stage));
}

[oploc1,viking_seer_up_ladder]
p_arrivedelay;
~climb_ladder(movecoord(coord, 0, 2, 0), true);

[oploc1,viking_seer_down_ladder]
p_arrivedelay;
~climb_ladder(movecoord(coord, 0, 2, 0), true);

[oploc1,viking_seer_trapdoor_open]
p_delay(0);
p_teleport(movecoord(coord, 0, -2, 0));

[oploc1,viking_seer_bookcase]
mes("You search the bookcase...");
p_delay(3);
if(inv_total(inv, viking_red_herring) > 0 | testbit(%viking_bits, ^viking_seerdoor_reddisk_2) = ^true) {
    mes("You find nothing of interest.");
    return;
}
inv_add(inv, viking_red_herring, 1);
