mes("You unscrew the lid of the vase.");
inv_del(inv, viking_airtight_vase_with_lid_frozen, 1);
inv_add(inv, viking_airtight_vase_frozen, 1);
inv_add(inv, viking_vase_lid, 1);

[opheldu,viking_airtight_vase]
switch_obj(last_useitem) {
    case viking_pointless_magnet :
        mes("You use the magnet on the vase. The metallic object inside moves.");
        mes("The neck of the vase is too thin for the object to come out of the vase.");
    case viking_pointless_pick :
        mes("This pick wouldn't be strong enough to break the vase open.");
    case viking_pointless_shiptoy :
        mes("It won't fit in there!");
    case viking_bucket_3, viking_bucket_4, viking_bucket_5 :
        inv_del(inv, last_useitem, 1);
        inv_add(inv, viking_bucket_empty, 1);
        inv_del(inv, viking_airtight_vase, 1);
        inv_add(inv, viking_airtight_vase_water, 1);
        mes("You fill the vase with water.");
    case viking_jug_3 :
        inv_del(inv, last_useitem, 1);
        inv_add(inv, viking_jug_empty, 1);
        inv_del(inv, viking_airtight_vase, 1);
        inv_add(inv, viking_airtight_vase_water, 1);
        mes("You fill the vase with water.");
    case viking_jug_1, viking_jug_2, viking_bucket_1, viking_bucket_2 :
        mes("There isn't enough water in the jug to fill the vase."); // yes, this says jug for buckets
    case viking_vase_lid :
        mes("You screw the lid on tightly.");
        inv_del(inv, viking_airtight_vase, 1);
        inv_del(inv, viking_vase_lid, 1);
        inv_add(inv, viking_airtight_vase_with_lid, 1);
}

