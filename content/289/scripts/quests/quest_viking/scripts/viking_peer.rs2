[oplocu,viking_seers_tap]
switch_obj(last_useitem) {
    case viking_jug_empty, viking_jug_1, viking_jug_2 :
        inv_setslot(inv, last_useslot, viking_jug_3, 1);
        mes("You fill the jug from the tap.");
    case viking_bucket_empty, viking_bucket_1, viking_bucket_2, viking_bucket_3, viking_bucket_4 :
        inv_setslot(inv, last_useslot, viking_bucket_5, 1);
        mes("You fill the bucket from the tap.");
    case viking_airtight_vase : // this one uses inv del + add
        mes("You fill the strange looking vase with water.");
        inv_del(inv, viking_airtight_vase, 1);
        inv_add(inv, viking_airtight_vase_water, 1);
    case viking_bucket_5 : mes("Your bucket is already full of water.");
    case viking_jug_3 : mes("Your jug is already full of water.");
    case default : ~displaymessage(^dm_default);
}

[oplocu,viking_seers_drain]
def_int $last_slot = last_useslot;
switch_obj(last_useitem) {
    case viking_jug_1, viking_jug_2, viking_jug_3 :
        anim(throw_bucketofwater, 0);
        sound_synth(holy_water_pour, 1, 0);
        inv_setslot(inv, $last_slot, viking_jug_empty, 1);
        mes("You empty the jug down the drain.");
    case viking_bucket_1, viking_bucket_2, viking_bucket_3, viking_bucket_4, viking_bucket_5 :
        anim(throw_bucketofwater, 0);
        sound_synth(holy_water_pour, 1, 0);
        inv_setslot(inv, $last_slot, viking_bucket_empty, 1);
        mes("You empty the bucket down the drain.");
    case viking_airtight_vase_water :
        mes("You empty the strange looking vase of water.");
        inv_del(inv, viking_airtight_vase_water, 1);
        inv_add(inv, viking_airtight_vase, 1);
    case viking_bucket_empty : mes("Your bucket is already empty.");
    case viking_jug_empty : mes("Your jug is already empty.");
    case viking_airtight_vase : mes("The vase is already empty.");
    case viking_pointless_magnet : mes("You use the magnet on the drain. It doesn't do anything.");
    case viking_pointless_shiptoy : mes("It won't fit through the grating.");
    case default : ~displaymessage(^dm_default);
}

