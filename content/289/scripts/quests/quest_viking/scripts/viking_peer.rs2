    return;
}

[opheldu,viking_vase_lid]
switch_obj(last_useitem) {
    case viking_pointless_magnet :
        mes("You use the magnet on the vase lid. It doesn't seem to be magnetic.");
    case viking_airtight_vase :
        mes("You screw the lid on tightly.");
        inv_del(inv, viking_airtight_vase, 1);
        inv_del(inv, viking_vase_lid, 1);
        inv_add(inv, viking_airtight_vase_with_lid, 1);
    case viking_airtight_vase_water :
        mes("You screw the lid on tightly.");
        inv_del(inv, viking_airtight_vase_water, 1);
        inv_del(inv, viking_vase_lid, 1);
        inv_add(inv, viking_airtight_vase_with_lid_water, 1);
    case viking_airtight_vase_frozen :
        mes("The ice prevents you screwing on the lid.");

}

[oploc1,viking_seers_mural]
if(testbit(%viking_bits, ^viking_seerdoor_reddisk_1) = ^true & testbit(%viking_bits, ^viking_seerdoor_reddisk_2) = ^true) {
    if(inv_total(inv, viking_vase_lid) = 0) {
        if(inv_freespace(inv) = 0) {
            mes("There's a vase lid here, but you don't have room to take it.");
            return;
        }
        mes("You take the vase lid back out of the mural.");
        inv_add(inv, viking_vase_lid, 1);
    }
}
mes("You study the mural... it appears to be missing something...");

if(testbit(%viking_bits, ^viking_seerdoor_reddisk_1) = ^true & testbit(%viking_bits, ^viking_seerdoor_reddisk_2) = ^true & inv_total(inv, viking_vase_lid) > 0) {
    if_setobject(inter_185:com_1, viking_dummy_lid, 10);
}

if_setobject(inter_185:com_9, viking_dummy_coin, 116);
if_setobject(inter_185:com_10, viking_dummy_coin, 116);
if_setobject(inter_185:com_11, viking_dummy_coin, 116);
if_setobject(inter_185:com_12, viking_dummy_coin, 116);
if_setobject(inter_185:com_13, viking_dummy_coin, 116);
if_setobject(inter_185:com_14, viking_dummy_coin, 116);
if(testbit(%viking_bits, ^viking_seerdoor_reddisk_1) = ^true) if_setobject(inter_185:com_15, viking_dummy_coin, 116);
else if_setobject(inter_185:com_15, viking_dummy_coin2, 116);

if(testbit(%viking_bits, ^viking_seerdoor_reddisk_2) = ^true) if_setobject(inter_185:com_16, viking_dummy_coin, 116);
else if_setobject(inter_185:com_16, viking_dummy_coin2, 116);

if_openmain(inter_185);

[oplocu,viking_seers_mural]
// this mural is kind of reworked in late 2006 to prevent skipping with drop trick
// using dupe coin -> You've already put the [old] red disk into the empty hole on the mural. and inv_del
def_obj $last_useitem = last_useitem;
p_arrivedelay;
if($last_useitem = viking_red_wooden_coin) {
    mes("You put the red disk into the empty hole on the mural.");
    mes("It is a perfect fit!");
    inv_del(inv, viking_red_wooden_coin, 1);
    if(testbit(%viking_bits, ^viking_seerdoor_reddisk_1) = ^false) %viking_bits = setbit(%viking_bits, ^viking_seerdoor_reddisk_1);
    else if(testbit(%viking_bits, ^viking_seerdoor_reddisk_2) = ^false) %viking_bits = setbit(%viking_bits, ^viking_seerdoor_reddisk_2);
    if(testbit(%viking_bits, ^viking_seerdoor_reddisk_1) = ^true & testbit(%viking_bits, ^viking_seerdoor_reddisk_2) = ^true) {
        mes("The center of the mural falls out!");
        inv_add(inv, viking_vase_lid, 1);
    }
    return;
}
~displaymessage(^dm_default);

[oploc1,viking_seer_trapdoor_closed]
mes("The trapdoor opens...");
sound_synth(door_open, 1, 0);
loc_change(viking_seer_trapdoor_open, 500);

[oploc2,viking_seer_trapdoor_open]
mes("The trapdoor closes...");
sound_synth(door_open, 1, 0);
loc_change(viking_seer_trapdoor_closed, 500);

[oploc1,viking_seers_door2]
if(inv_total(inv, viking_key) > 0 & ~check_axis(coord, loc_coord, loc_angle) = false) {
    @unlock_viking_seers_door2;
}
mes("This door is locked tightly shut.");

[oplocu,viking_seers_door2]
if(last_useitem = viking_key & ~check_axis(coord, loc_coord, loc_angle) = false) {
    @unlock_viking_seers_door2;
}

[label,unlock_viking_seers_door2]
~clear_peer_trial_items;
mes("You unlock the door with your key.");
~open_and_close_door2(viking_door_inactive, false, door_open);
p_delay(0);
if(~get_viking_peer_progress < ^peer_complete) {
    // no trial complete message : https://youtu.be/NkAJ8-1A0cY?si=gMDfKRKlanOginJF&t=1839
    %viking = add(%viking, 1);
    ~set_viking_peer_progress(^peer_complete);
    if(npc_find(coord, viking_peer, 7, 0) = true) ~chatnpc("<p,shock>Incredible! To have solved my puzzle so quickly! I have no choice but to vote in your favour!");
}

[proc,clear_peer_trial_items]
inv_del(inv, viking_pointless_magnet, ^max_32bit_int);
inv_del(inv, viking_pointless_thread, ^max_32bit_int);
inv_del(inv, viking_pointless_pick, ^max_32bit_int);
inv_del(inv, viking_pointless_shiptoy, ^max_32bit_int);
