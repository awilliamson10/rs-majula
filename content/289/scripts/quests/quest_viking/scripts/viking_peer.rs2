[oploc1,viking_unimountedhead]
if(testbit(%viking_bits, ^viking_seerdoor_reddisk_1) = ^true) {
    ~mesbox("There is a hole in this unicorn head where a left eye should be.");
    return;
}
~mesbox("You notice there is something unusual about the left eye of this unicorn head...");
if(inv_total(inv, viking_red_wooden_coin) > 0) {
    mes("It's unusual because you've already taken it!");
