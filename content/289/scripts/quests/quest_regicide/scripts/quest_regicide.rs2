[oploc1,regicide_logbalance1_start] @regicide_logbalance(2200);
[oploc1,regicide_logbalance2_start] @regicide_logbalance(2261);

// todo: recheck this one cause i'm guessing the delays shouldnt match osrs
[oploc1,regicide_logbalance3_start]
if(stat(agility) < 45) {
    mes("You need to be level 45 agility to cross this log."); // rs3
    return;
}
def_int $dz = -2;
// cant use loc_angle and they have random pauses in the middle for some reason...
if(coordz(loc_coord) < 3235) {
    $dz = 2;
}
~set_readywalk_bas(human_walk_logbalance_ready, human_walk_logbalance);
sound_synth(log_balance, 2, 0);
~forcemove(loc_coord);
~forcemove(movecoord(coord, 0, 0, $dz));
sound_synth(log_balance, 2, 0);
~forcemove(movecoord(coord, 0, 0, $dz));
p_delay(0);
sound_synth(log_balance, 2, 0);
~forcemove(movecoord(coord, 0, 0, $dz));
~update_bas;

// https://www.youtube.com/watch?v=1QO8LtDwwMg&t=1462s works differently than osrs
[label,regicide_logbalance](int $center_coord)
if(stat(agility) < 45) {
    mes("You need to be level 45 agility to cross this log."); // rs3
    return;
}
def_int $dx = -2;
// cant use loc_angle and they have random pauses in the middle for some reason...
if(coordx(loc_coord) < $center_coord) {
    $dx = 2;
}
~set_readywalk_bas(human_walk_logbalance_ready, human_walk_logbalance);
sound_synth(log_balance, 2, 0);
~forcemove(loc_coord);
~forcemove(movecoord(coord, divide($dx, 2), 0, 0));
sound_synth(log_balance, 2, 0);
~forcemove(movecoord(coord, $dx, 0, 0));
p_delay(0);
sound_synth(log_balance, 2, 0);
~forcemove(movecoord(coord, $dx, 0, 0));
~update_bas;

[oploc1,_regicide_cross_over]
if(%regicide_quest < ^regicide_spoken_tracker2) {
    mes("You can see no way to get past this.");
    return;
}
if(loc_type = regicide_cross_over2_tyras_camp) {
    if(%regicide_quest < ^regicide_defeated_guard) {
        if(npc_find(coord, regicide_tyras_camp_guard, 7, 0) = true & add(%npc_lastcombat, 8) <= map_clock) {
            @regicide_camp_guard_attack;
        }
        npc_add(coord, regicide_tyras_camp_guard, 500);
        @regicide_camp_guard_attack;
    }
}
// wiki (incl rs3) says only 1 side has a check, but testing on rs3 both sides have the check
// and you can get stuck
if(stat(agility) < 56) {
    mes("You need to be level 56 agility to pass this.");
    return;
}
def_coord $dest;
def_coord $start;
def_int $dir;
def_seq $seq;
def_coord $lb;
def_coord $ub;
def_synth $synth;
def_int $synth_delay = 0;
switch_loc (loc_type) {
    case regicide_cross_over1, regicide_cross_over1_tyras_camp : 
        $seq = human_walk_style;
        $synth = forest_lowwall;
        $synth_delay = 30;
    case regicide_cross_over2, regicide_cross_over2_tyras_camp : 
        $seq = human_doublepipesqueeze;
        $synth = forest_doublesqueeze;
        $synth_delay = 30;
    case regicide_cross_over3 : 
        $seq = regicide_tightfit;
        $synth = forest_sidesqueeze;
        $synth_delay = 40;
}
switch_int(loc_angle) {
    case ^loc_north, ^loc_south :
        if(coordx(coord) < coordx(loc_coord)) {
            $start = movecoord(loc_coord, -1, 0, 1);
            $dest = movecoord(loc_coord, 2, 0, 1);
            $dir = ^exact_east;
        } else {
            $start = movecoord(loc_coord, 2, 0, 1);
            $dest = movecoord(loc_coord, -1, 0, 1);
            $dir = ^exact_west;
        }
        $lb = movecoord($start, 0, 0, -1);
        $ub = movecoord($dest, 0, 0, 1);
    case ^loc_east, ^loc_west :
        if(coordz(coord) < coordz(loc_coord)) {
            $start = movecoord(loc_coord, 1, 0, -1);
            $dest = movecoord(loc_coord, 1, 0, 2);
            $dir = ^exact_north;
        } else {
            $start = movecoord(loc_coord, 1, 0, 2);
            $dest = movecoord(loc_coord, 1, 0, -1);
            $dir = ^exact_south;
        }
        $lb = movecoord(loc_coord, 0, 0, -1);
        $ub = movecoord(loc_coord, 2, 0, 2);
}
if(distance(coord, $start) > 1) {
    return;
}
anim($seq, 30);
sound_synth($synth, 1, $synth_delay);
p_locmerge(30, 94, $lb, $ub); 
p_exactmove($start, $dest, 30, 94, $dir);
p_delay(3);
if(coord = 0_34_49_55_13 & %regicide_quest = ^regicide_spoken_tracker2) {
    ~spawn_tyras_guard;
}
if(loc_type = regicide_cross_over2_tyras_camp) {
    if(%regicide_quest = ^regicide_defeated_guard) {
        %regicide_quest = ^regicide_entered_camp;
    }
}
// specfically this loc, not 100% sure on the inzone check need to confirm
if(loc_type = regicide_cross_over3) {
    if(testbit(%regicide_bits, ^regicide_given_rabbit) = ^true & inzone(0_34_49_0_0, 0_34_49_63_63, coord) = true) {
        %regicide_bits = clearbit(%regicide_bits, ^regicide_given_rabbit);
    }
}

[label,regicide_camp_guard_attack]
~chatnpc("<p,neutral>I remember you! You're the one who's working with them wicked elves. I will make you pay for that mistake.");
~npc_retaliate(0);

[oploc1,regicide_old_camp_footprints]
if(%regicide_quest = ^regicide_defeated_guard) {
    mes("I know where those tracks lead.");
} else if(%regicide_quest = ^regicide_spoken_tracker2) {
    mes("The tracks lead through the dense wood, you can follow them now.");
} else if(%regicide_quest = ^regicide_shown_pendant) {
    %regicide_quest = ^regicide_found_footprints;
    mes("You try to follow the foot prints but they lead into impassable woodland.");
} else if (%regicide_quest < ^regicide_shown_pendant) {
    mes("You are unable to make anything of the markings.");
}

[oplocu,regicide_catapult]
if(%regicide_quest >= ^regicide_killed_tyras) {
    mes("I think I've done enough damage with that.");
    return;
}
if(testbit(%regicide_bits, ^regicide_given_rabbit) = ^false) {
    if(npc_find(coord, regicide_tyras_lazy_guard, 8, 0) = true) ~chatnpc("<p,neutral>Oi! Don't mess with that.");
    return;
}
if(last_useitem = regicide_barrel_lid_fused) {
    if(%regicide_quest ! ^regicide_spoken_iorwerth2) {
        return;
    }
    if(%regicide_catapult_used = ^true) {
        mes("The catapult is being used"); // complete guess
        return;
    }
    %regicide_catapult_used = ^true;
    p_delay(0);
    ~forcewalk2(0_34_49_11_49);
    facesquare(movecoord(coord, 0, 0, 1));
    p_delay(1);
    anim(regicide_catapultwind, 0);
    loc_anim(winddown_catapult);
    sound_synth(catapult_winch, 1, 0);
    if(.loc_find(0_34_49_10_47, regicide_catapult_left) = true) {
        .loc_anim(wind_catapult);
    }
    p_delay(1);
    ~forcewalk2(0_34_49_9_52);
    facesquare(movecoord(coord, 0, 0, -1));
    p_delay(0);
    anim(human_pickupfloor, 0);
    inv_del(inv, regicide_barrel_lid_fused, 1);
    loc_anim(unlitbarrel);
    ~forcewalk2(0_34_49_7_49);
    p_delay(0);
    anim(regicide_catapault_trigger, 0);
    if(.loc_find(0_34_49_8_47, regicide_catapult_right) = true) {
        .loc_anim(trigger_catapult);
    }
    loc_anim(fire_catapult);
    sound_synth(catapult_fire, 1, 0);
    ~coord_projectile(0_34_49_9_49, 0_34_49_10_6, spotanim_286, 138, 75, 50, 30, 170, 0, 0);
    %regicide_catapult_used = ^false;
    p_delay(4);
    anim(regicide_player_vanish, 0);
    p_teleport(0_36_71_10_6);
    p_delay(0);
    spotanim_map(spotanim_287, 0_36_71_10_6, 194, 100);
    sound_synth(barrel_incoming, 1, 35);
    ~coord_projectile(0_36_71_10_18, 0_36_71_10_7, spotanim_286, 112, 100, 10, 30, 90, 0, 0);
    p_delay(2);
    anim(regicide_player_vanish, 0);
    loc_add(0_36_71_13_6, regicide_tent_human_fire, 0, wall_straight, 10);
    loc_add(0_36_71_8_7, regicide_tent_human_fire, 2, wall_diagonal, 10);
    loc_add(0_36_71_8_5, regicide_tent_human_fire, 1, wall_diagonal, 10);
    loc_add(0_36_71_12_5, regicide_tent_human_fire, 0, wall_diagonal, 10);
    loc_add(0_36_71_12_7, regicide_tent_human_fire, 3, wall_diagonal, 10);

