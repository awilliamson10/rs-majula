    loc_add(0_36_71_10_4, regicide_tent_human_fire, 1, wall_straight, 10);
    loc_add(0_36_71_11_4, regicide_tent_human_fire, 1, wall_straight, 10);

    loc_add(0_36_71_8_4, regicide_tent_human_fire, 1, wall_diagonalcorner, 10);
    loc_add(0_36_71_12_4, regicide_tent_human_fire, 0, wall_diagonalcorner, 10);
    loc_add(0_36_71_13_5, regicide_tent_human_fire, 0, wall_diagonalcorner, 10);
    loc_add(0_36_71_13_7, regicide_tent_human_fire, 3, wall_diagonalcorner, 10);

