    loc_add(0_36_71_9_7, flamming_tent_roof, 3, centrepiece_straight, 10);
    loc_add(0_36_71_10_7, flamming_tent_roof, 3, centrepiece_straight, 10);
    loc_add(0_36_71_11_7, flamming_tent_roof, 3, centrepiece_straight, 10);

    loc_add(0_36_71_8_6, flamming_tent_roof, 2, centrepiece_straight, 10);
