    loc_add(0_36_71_7_7, regicide_tent_human_fire, 2, wall_diagonalcorner, 10);
    sound_synth(bigfire, 1, 0);
    p_delay(7);
    anim(regicide_player_vanish, 0);
    p_teleport(0_34_49_7_49);
    %regicide_quest = ^regicide_killed_tyras;
    p_delay(3);
    anim(null, 0);
    return;
}
mes("I don't want to use that for ammo.");

[proc,spawn_tyras_guard]
if(testbit(%regicide_bits, ^regicide_seen_guard) = ^true) { 
    return;
}
// TODO: check this spawn time
%regicide_bits = setbit(%regicide_bits, ^regicide_seen_guard);
npc_add(map_findsquare(0_34_49_52_10, 0, 1, ^vis_lineofwalk), regicide_old_camp_guard, 500);
npc_say("I see you making nice with that elf, traitor!");
~npc_retaliate(0);

[oploc1,regicide_tent_door]
if(npc_findexact(movecoord(loc_coord, -1, 0, 0), regicide_tyras_camp_tent_guard) = true) {
    if(%regicide_quest > ^regicide_spoken_iorwerth2) {
        ~chatnpc("<p,neutral>You cannot enter! This is now General Hining's pavilion. Since the king's death he has held us together.");
        ~chatplayer("<p,quiz>You're not going home to Ardougne then?");
        ~chatnpc("<p,sad>I wish I could. Just to see my wife, but if we don't stop the evil here, it will be too late!");
        ~chatplayer("<p,quiz>Evil?");
        ~chatnpc("<p,scared>Soon Zamorak's fury will be released upon us.");
        return;
    }
    ~chatnpc("<p,neutral>You cannot pass! These are the king's quarters. No one enters without invitation.");
    ~chatplayer("<p,neutral>How do I get an invitation?");
    ~chatnpc("<p,neutral>If the king wants to see you he will ask for you.");
    ~chatplayer("<p,neutral>What's the chances of that?");
    ~chatnpc("<p,neutral>Absolutely none! Now let me get on with my job.");
}

[opheldu,regicide_sulphar]
~attempt_grind_ingredient(last_useslot, last_slot);

[oploc1,_regicide_sulphar]
inv_add(inv, regicide_sulphar, 1);
mes("You break off a piece of the formation.");

[oploc1,regicide_tar_collection]
mes("I need something to hold the coal tar.");

[oplocu,regicide_tar_collection]
if(last_useitem = regicide_barrel_empty) {
    inv_del(inv, regicide_barrel_empty, 1);
    inv_add(inv, regicide_barrel_tar, 1);
    anim(human_pickupfloor, 0);
    mes("You fill the barrel with tar.");
    return;
}
~displaymessage(^dm_default);

[label,regicide_heat_quicklime]
p_arrivedelay;
if(%regicide_quest < ^regicide_spoken_iorwerth2) {
    // typo intentional
    ~objbox(limestone, "I see no reason put this in the furnace.", 250, 0, 0);
    return;
}
// https://youtu.be/wwJXlduVaxE?si=jDQIFE4TMqyDFFvO&t=513
mes("You put the lime stone in the furnace.");
anim(human_furnace, 0);
sound_synth(furnace, 1, 0);
p_delay(3);
inv_del(inv, limestone, 1);
inv_add(inv, regicide_quicklime, 1);
anim(human_furnace, 0);
sound_synth(sizzle, 1, 0);
if(inv_totalcat(worn, armour_hands) > 0) {
    mes("You retrieve a block of quicklime.");
    return;
}
mes("You feel the quicklime corroding your skin.");
~damage_self(8);

[oplocu,regicide_loom]
if(last_useitem = ball_of_wool) {
    if(stat(crafting) < 10) {
        ~mesbox("You need level 10 Crafting to make that."); // osrs
        return;
    }
    if(inv_total(inv, ball_of_wool) < 4) {
        ~mesbox("You don't have enough of that item to weave it into anything at this loom."); // OSRS, almost certainly wrong for pre-farming/weakqueue loom
        return;
    }
    p_arrivedelay;
    anim(regicide_useloom, 0);
    sound_synth(loom, 1, 0);
    p_delay(2);
    mes("You weave the balls of wool into a strip of cloth.");
    inv_del(inv, ball_of_wool, 4);
    inv_add(inv, regicide_cloth, 1);
    return;
}
~displaymessage(^dm_default);

[oplocu,regicide_furnace]
@use_furnace;

[opheldu,regicide_quicklime]
if(last_useitem = pestle_and_mortar) {
    inv_del(inv, regicide_quicklime, 1);
    anim(human_herbing_grind, 0);
    sound_synth(grind, 1, 0);
    if(inv_total(inv, pot_empty) = 0) {
        mes("You burn yourself on the caustic dust before spilling it on the ground.");
        mes("Maybe you need something to store it in.");
        ~damage_self(5);
        return;
    }
    mes("You grind the quicklime to dust and store it in a pot."); // osrs sends this first before the fail mes, rs3 doesn't, not sure which is right
    inv_del(inv, pot_empty, 1);
    inv_add(inv, regicide_quicklime_dust, 1);
    return;
}
~displaymessage(^dm_default);

[opheldu,regicide_barrel_tar]
mes("I don't want to contaminate the coal tar."); // no item check

[opheldu,regicide_barrel_naphtha]
if(last_useitem = regicide_quicklime | last_useitem = regicide_sulphar) {
    mes("I think I should powder this first.");
    return;
}
if(last_useitem = regicide_quicklime_dust) {
    mes("You mix the quicklime dust into the naphtha.");
    inv_del(inv, regicide_quicklime_dust, 1);
    inv_del(inv, regicide_barrel_naphtha, 1);
    inv_add(inv, regicide_barrel_naphtha_quicklime_mix, 1);
    return;
}
if(last_useitem = regicide_sulphar_dust) {
    mes("You mix the sulphur dust into the naphtha.");
    inv_del(inv, regicide_sulphar_dust, 1);
    inv_del(inv, regicide_barrel_naphtha, 1);
    inv_add(inv, regicide_barrel_naphtha_sulphar_mix, 1);
    return;
}
~displaymessage(^dm_default);

[opheldu,regicide_barrel_naphtha_quicklime_mix]
if(last_useitem = regicide_quicklime | last_useitem = regicide_sulphar) {
    mes("I think I should powder this first.");
    return;
}
if(last_useitem = regicide_quicklime_dust) {
    mes("There is quicklime mixed into the naphtha already.");
    return;
}
if(last_useitem = regicide_sulphar_dust) {
    mes("You mix the sulphur dust into the naphtha and seal the barrel.");
    mes("Now you just need to make a fuse for it.");
    inv_del(inv, regicide_sulphar_dust, 1);
    inv_del(inv, regicide_barrel_naphtha_quicklime_mix, 1);
    inv_add(inv, regicide_barrel_lid, 1);
    return;
}
~displaymessage(^dm_default);

[opheldu,regicide_barrel_naphtha_sulphar_mix]
if(last_useitem = regicide_quicklime | last_useitem = regicide_sulphar) {
    mes("I think I should powder this first.");
    return;
}
if(last_useitem = regicide_quicklime_dust) {
    mes("You mix the quicklime dust into the naphtha and seal the barrel.");
    mes("Now you just need to make a fuse for it.");
    inv_del(inv, regicide_quicklime_dust, 1);
    inv_del(inv, regicide_barrel_naphtha_sulphar_mix, 1);
    inv_add(inv, regicide_barrel_lid, 1);
    return;
}
if(last_useitem = regicide_sulphar_dust) {
    mes("There is sulphur mixed into the naphtha already.");
    return;
}
~displaymessage(^dm_default);

[opheldu,regicide_barrel_lid]
if(last_useitem = ball_of_wool) { // yes, this interaction only works one way
    mes("The wool is too thin to fit well, maybe if I weave a load of it together it will work.");
    return;
}
if(last_useitem = regicide_cloth) {
    mes("You stuff cloth through a hole in the barrel to make a fuse.");
    inv_del(inv, regicide_cloth, 1);
    inv_del(inv, regicide_barrel_lid, 1);
    inv_add(inv, regicide_barrel_lid_fused, 1);
    return;
}
~displaymessage(^dm_default);

// this is how the dialogue works on RS3 and seems to be how it used to work 
// on osrs
[queue,arianwyn_dialogue](int $val)
if($val > 15) {
    return;
}
p_walk(coord);
queue(arianwyn_dialogue, 0, add($val, 1));
if(npc_find(coord, regicide_good_elf3, 5, 0) = false) {
    npc_add(map_findsquare(coord, 1, 3, ^vis_lineofsight), regicide_good_elf3, 300); // 3 mins rs3
}
if(npc_find(coord, regicide_good_elf3, 5, 0) = true) {
    if($val = 0) ~chatnpc("<p,neutral>Are you the human by the name <displayname()>?");
    if($val = 1) ~chatplayer("<p,neutral>Yes, that's me?!?");
    if($val = 2) ~chatnpc("<p,happy>Thank Seren, maybe all is not yet lost.");
    if($val = 3) ~chatplayer("<p,confused>What do you mean?");
    if($val = 4) ~chatnpc("<p,neutral>It was you that murdered King Tyras, do not bother to deny it, I was watching.");
    if($val = 5) ~chatnpc("<p,neutral>There is much to explain and little time. You carry a message from Lord Iorwerth do you not.");
    if($val = 6) ~chatplayer("<p,neutral>Well you seem to know everything else so I'll not lie. Yes.");
    if($val = 7) ~chatnpc("<p,neutral>Good, we understand each other well. Now hand it here and find the truth of who your real employer is.");
    if($val = 8) ~objbox(regicide_iorwerth_message, "You show the message to the elf, he moves his lips silently and the seal on the message is parted.", 250, 0, 0);
    if($val = 9) {
        ~regicide_iowerth_message_scroll;
        p_pausebutton;
    }
    if($val = 10) ~chatplayer("<p,neutral>I had no idea!");
    if($val = 11) ~chatnpc("<p,neutral>There is still a chance to stop this. But we must be careful, or they will push their plans forward and act before we're ready.");
    if($val = 12) ~chatnpc("<p,neutral>Give the message to King Lathas, He will not see my little spell. Act like nothing unusual happened. You're going to be our man on the inside.");
    if($val = 13) ~chatplayer("<p,neutral>You want me to spy?!? OK what's in it for me?");
    if($val = 14) ~chatnpc("<p,neutral>How can I put this... This isn't a struggle for land or title. It is a war for life, all life. If the gate to Zamoraks world is opened we all die.");
    if($val = 15) {
        %regicide_quest = ^regicide_spoken_arianwyn;
        ~chatnpc("<p,neutral>Deliver your message, act normal. We'll be in touch.");
    }
}

[zone,0_40_51_24_32]
if(%regicide_quest = ^regicide_reported_iorwerth & inv_total(inv, regicide_iorwerth_message) > 0) {
    p_stopaction;
    queue(arianwyn_dialogue, 0, 0);
}

[opheld1,regicide_iorwerth_message]
if(%regicide_quest > ^regicide_reported_iorwerth) {
    ~regicide_iowerth_message_scroll;
    return;
}
mes("You try to open the message...");
mes("The seal on the scroll is unbreakable.");

[proc,regicide_iowerth_message_scroll]
// https://web.archive.org/web/20061231211932im_/http://www.runeweb.net/fireball/Regicide%20Images/Regicide27.PNG
if_settext(inter_102:com_3, "Your Majesty King Lathas");
if_settext(inter_102:com_1, "Your man did well. The path is now open");
if_settext(inter_102:com_4, "for the dark lord to enter this realm.");
if_settext(inter_102:com_5, "You will yet live to see Camelot crushed");
if_settext(inter_102:com_8, "under foot.");
if_settext(inter_102:com_6, "Warmaster Iorwerth");
if_openmain(inter_102);

[queue,quest_regicide_complete]
inv_add(inv, coins, 15000);
stat_advance(agility, 137500);
%regicide_quest = ^regicide_complete;
session_log(^log_adventure, "Quest complete: Regicide");
~send_quest_complete(questlist:regicide, regicide_alchemy_symbol4, 250, ^regicide_questpoints, "You have completed the\\nRegicide Quest!");
