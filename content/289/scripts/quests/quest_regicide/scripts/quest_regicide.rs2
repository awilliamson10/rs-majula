    loc_add(0_36_71_9_6, regicide_tentroof_stump, 0, centrepiece_straight, 10);
    loc_add(0_36_71_11_6, regicide_tentroof_stump, 3, centrepiece_straight, 10);

    if(loc_find(0_36_71_10_6, regicide_tentroof_high_centre) = true) loc_del(10);
    if(loc_find(0_36_71_8_4, regicide_propbarrel) = true) loc_anim(propbarrel_exploding);
    if(loc_find(0_36_71_13_7, regicide_propbarrel) = true) loc_anim(propbarrel_exploding);

    loc_add(0_36_71_10_8, regicide_tent_human_fire, 3, wall_straight, 10);
    loc_add(0_36_71_9_8, regicide_tent_human_fire, 3, wall_straight, 10);
