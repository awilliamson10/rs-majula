[opnpc1,elf_city_guard]
~chatplayer("<p,quiz>Hello, please can you open the gate?");
~chatnpc("<p,neutral>I'm sorry but no humans may enter Prifddinas while those criminals are at large.");
~chatplayer("<p,neutral>I'm no criminal.");
~chatnpc("<p,neutral>Rules are rules. No one enters until the brigands are gone.");

[label,prif_guard_halt]
if(npc_find(coord, elf_city_guard, 7, 0) = true) {
    ~chatnpc("<p,neutral>Halt!|No humans may enter the city of Prifddinas.");
}

[oploc1,elf_city_gate_left] @prif_guard_halt;
[oploc1,elf_city_gate_right] @prif_guard_halt;
