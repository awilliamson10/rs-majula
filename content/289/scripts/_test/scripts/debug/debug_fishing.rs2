[debugproc,fishtest]
inv_add(inv, feather, 10000);
inv_add(inv, fishing_bait, 10000);
inv_add(inv, fishing_rod, 1);
inv_add(inv, fly_fishing_rod, 1);
inv_add(inv, net, 1);
inv_add(inv, big_net, 1);

[debugproc,fishspots](npc $npc)
if (nc_param($npc, fishing_movement_enum) = null) {
    mes("No movement spots found for that npc.");
    return;
}
def_int $output_count = enum_getoutputcount(nc_param($npc, fishing_movement_enum));
def_coord $coord;
mes("Placing Ana in all possible spots for that npc. (<tostring($output_count)> total)");
def_int $i = 0;
while ($i < $output_count) {
    $coord = enum(int, coord, nc_param($npc, fishing_movement_enum), $i);
    obj_add($coord, thanainabarrel, 1, 5000);
    $i = calc($i + 1);
}
