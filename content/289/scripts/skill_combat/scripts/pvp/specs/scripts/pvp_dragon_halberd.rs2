[label,pvp_dragon_halberd_sa]
~set_sa_vars(oc_param(inv_getobj(worn, ^wearpos_rhand), sa_energy));
~set_pk_vars;
def_spotanim $spot;
def_int $dir;
def_coord $spot_coord;
// spotanim 
if(coordz(coord) > coordz(.coord)) {
    $spot = spotanim_282;
    $spot_coord = movecoord(coord, 0, 0, -1);
    $dir = ^exact_south;
} else if(coordz(coord) < coordz(.coord)) {
    $spot = spotanim_283;
    $spot_coord = movecoord(coord, 0, 0, 1);
    $dir = ^exact_north;
} else if(coordx(coord) < coordx(.coord)) {
    $spot = spotanim_284;
    $spot_coord = movecoord(coord, 1, 0, 0);
    $dir = ^exact_east;
} else {
    $spot = spotanim_285;
    $spot_coord = movecoord(coord, -1, 0, 0);
    $dir = ^exact_west;
}
anim(dragon_halberd_special_attack, 0);
sound_synth(halberd_swipe, 1, 0);
spotanim_map($spot, $spot_coord, 92, 0);
.anim(.%com_defendanim, 20);
.sound_synth(halberd_swipe, 1, 0);

~pvp_dragon_halberd_spec_hit(100);

def_coord $center = .coord;
def_coord $side1;
def_coord $side2;
if ($dir = ^exact_north | $dir = ^exact_south) {
    $side1 = movecoord($center, 1, 0, 0); 
    $side2 = movecoord($center, -1, 0, 0);
} else {
    $side1 = movecoord($center, 0, 0, 1);
    $side2 = movecoord($center, 0, 0, -1);
}
huntall($center, 1, ^vis_lineofsight);
while (.huntnext = true) {
    if ($center ! .coord & map_multiway($center) = true & map_multiway(.coord) = true) {
        if (.coord = $side1 | .coord = $side2) {
            ~pvp_dragon_halberd_spec_hit(75);
        }
    }
}

[proc,pvp_dragon_halberd_spec_hit](int $scale)
if (stat(hitpoints) = 0) {
    return;
}
if (~pvp_is_attackable = false) {
    return;
}
def_int $damage = 0;
def_int $maxhit = scale(110, 100, %com_maxhit);
def_int $attack_roll = scale($scale, 100, ~player_attack_roll_specific(%damagetype));
def_int $defence_roll = ~.player_defence_roll_specific(^slash_style);
if (randominc($attack_roll) > randominc($defence_roll)) {
    if (~.check_protect_prayer(^melee_style) = true) {
        $maxhit = scale(6, 10, $maxhit); // reduction of 40%
    }
    $damage = min(randominc($maxhit), .stat(hitpoints)); // tick eating existed! https://oldschool.runescape.wiki/w/Update:The_Wintertodt
    ~give_combat_experience_pvp(%damagestyle, $damage, ~pvp_xp_multiplier(~.player_combat_level));
    both_heropoints($damage);
}
.queue*(pvp_retaliate, 0)(uid);
~.pvp_damage(0, $damage);
